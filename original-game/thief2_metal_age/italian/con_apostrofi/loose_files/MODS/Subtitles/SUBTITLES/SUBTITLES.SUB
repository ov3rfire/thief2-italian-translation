{
	Type	"player"
	Descr	"Garrett"

	Sub	"GAR0100"	{	Text	"D'accordo, Basso, resta fermo finche' non ti do il segnale."	}

	Sub	"GAR0101"	{	Text	"Meglio controllare la mappa."	}

	Sub	"GAR0102"	{	Text	"Questa dev'essere la porta di cui parlava Basso."	}

	Sub	"GAR0103"	{	Text	"Meno male che il maggiordomo e' fuori per la notte... Ha lasciato le luci accese."	}

	Sub	"GAR0104"	{	Text	"Di sopra... Basso non avra' bisogno di salire fin qui."	}

	Sub	"GAR0105"	{	Text	"Oooh... Meglio fermarsi e controllare quella luce dietro l'angolo."	}

	Sub	"GAR0106"	{	Text	"Questo corridoio e' troppo illuminato. Meglio spegnere quella torcia con una freccia d'acqua."	}

	Sub	"GAR0107"	{	Text	"Attento."	}

	Sub	"GAR0108"	{	Text	"Un'altra guardia piu' avanti. E' il momento di stenderla mentre e' di spalle."	}

	Sub	"GAR0109"	{	Text	"Mettiamoci da parte e aspettiamo."	}

	Sub	"GAR0110"	{	Text	"Mettiamoci, ehm, da parte e aspettiamo che questa chiacchierata finisca."	}

	Sub	"GAR0111"	{	Text	"Fermo-o... Fermo-oo..."	}

	Sub	"GAR0112"	{	Text	"Bene, quella e' la sua porta. Immagino che Basso possa aprirla. Non e' un gran furtivo, ma con le serrature ci sa fare eccome."	}

	Sub	"GAR0113"	{	Text	"Sembra che ora la strada sia libera per Basso."	}
}

{
	Type	"convo"
	Descr	"Basso"

	Sub	"BAS0101A"	{	Text	"Ho fatto scattare la serratura della porta laterale per te, Garrett. E' l'unico buon modo per entrare."	}
}

{
	Type	"convo"
	Descr	"Jennivere"

	Sub	"JEN0102A"	{	Text	"Basso!"	}
}

{
	Type	"convo"
	Descr	"Basso"

	Sub	"BAS0102B"	{	Text	"Shhh... Vieni con me."	}
}

{
	Type	"convo"
	Descr	"Guard 1"

	Sub	"SG60103A"	{	Text	"Dannate torce, sempre a spegnersi."	}
}

{
	Type	"convo"
	Descr	"Guard 2"

	Sub	"SG50103B"	{	Text	"Beh, non stare li' a farne una tragedia, riaccendila."	}
}

{
	Type	"convo"
	Descr	"Guard 1"

	Sub	"SG60103C"	{	Text	"Ho perso l'acciarino. P-perche' non lo fai tu?"	}
}

{
	Type	"convo"
	Descr	"Guard 2"

	Sub	"SG50103D"	{	Text	"Non sono io quello che si lamenta, o sbaglio?"	}
}

{
	Type	"convo"
	Descr	"Guard 1"

	Sub	"SG60103E"	{	Text	"Humph..."	}
}

{
	Type	"convo"
	Descr	"Basso"

	Sub	"BAS0101B"	{	Text	"Jenni, sono io! Basso!"	}
}

{
	Type	"convo"
	Descr	"Jennivere"

	Sub	"JEN0101C"	{	Text	"Chi... chi e'?"	}

	Sub	"JEN0101D"	{	Text	"Basso, sei tu?"	}
}

