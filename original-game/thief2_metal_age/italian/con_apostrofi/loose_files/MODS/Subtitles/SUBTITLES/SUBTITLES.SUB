{
	Type	"player"
	Descr	"Garrett"

	Sub	"GAR0701"	{	Text	"Mi chiedo se qualcuna delle finestre esterne possa essere aperta."	}

	Sub	"GAR0702"	{	Text	"Sembra che potrei riuscire ad arrampicarmi sul tetto."	}

	Sub	"GAR0703"	{	Text	"Certi individui in questa citta' sono troppo ricchi per il loro bene. Fortunati loro che ci sono io a dare una mano."	}

	Sub	"GAR0704"	{	Text	"Ora devo trovare qualche informazione utile."	}

	Sub	"GAR0705"	{	Text	"Non riusciro' mai ad attraversare qui con tutte quelle macchine di sicurezza attive."	}

	Sub	"GAR0706"	{	Text	"Forse posso trovare un modo per disattivarle."	}

	Sub	"GAR0707"	{	Text	"Il caveau non si aprira' finche' quella barra di chiusura non sara' tolta di mezzo."	}

	Sub	"GAR0708"	{	Text	"Che strano marchingegno. Vediamo che cosa fanno questi comandi."	}

	Sub	"GAR0709"	{	Text	"Heh-heh-heh... Ora si' che so di essere un maestro ladro: entro dritto dritto in un caveau di banca. E' ora di trovare la registrazione."	}
}

{
	Type	"convo"
	Descr	"Guard 1"

	Sub	"SG10701A"	{	Text	"Heh. Turno di notte di nuovo, eh Mart? Hai fatto arrabbiare il Master Banker o cosa?"	}
}

{
	Type	"convo"
	Descr	"Guard 2"

	MultiSub	"SG50701B"
	{
		{	Time	"0"	Length	"10000"	Text	"Naah, preferisco il turno di notte. E' tranquillo... e non devo inchinarmi e strisciare davanti ai clienti."	}
		{	Time	"7500"	Length	"10000"	Text	"(In tono canzonatorio) Lasciate che porti io il vostro pesante, pesantissimo oro, Lady Fondoschiena."	}
	}
}

{
	Type	"convo"
	Descr	"Guard 1"

	Sub	"SG10701C"	{	Text	"Ecco, lasciate che vi tolga di mano un po' di quella roba brutta e pesante, Lord Dunswick."	}
}

{
	Type	"convo"
	Descr	"Guard 2"

	Sub	"SG50701D"	{	Text	"Gia', e stanotte i capi non sono in giro ad ascoltarci parlare."	}
}

{
	Type	"convo"
	Descr	"Guard 1"

	Sub	"SG30702A"	{	Text	"Ti capita mai di chiederti, guardando tutto questo...?"	}
}

{
	Type	"convo"
	Descr	"Guard 2"

	Sub	"SG50702B"	{	Text	"Chiedermi cosa?"	}
}

{
	Type	"convo"
	Descr	"Guard 1"

	Sub	"SG30702C"	{	Text	"Beh... da dove viene tutto il denaro per il marmo elegante, e-e le incisioni, e le opere d'arte?"	}
}

{
	Type	"convo"
	Descr	"Guard 2"

	Sub	"SG50702D"	{	Text	"D-da tutte le persone che affidano il loro denaro alla banca."	}
}

{
	Type	"convo"
	Descr	"Guard 1"

	Sub	"SG30702E"	{	Text	"Nooo no-no... Se la banca lo spende per le cose eleganti... e se poi lo rivogliono indietro?"	}
}

{
	Type	"convo"
	Descr	"Guard 2"

	Sub	"SG50702F"	{	Text	"B-b-beh, magari alcuni di loro muoiono prima e non lo chiedono mai indietro."	}
}

{
	Type	"convo"
	Descr	"Guard 1"

	Sub	"SG30702G"	{	Text	"Beeeh... puo' darsi... Io tengo il mio oro a casa... chiuso a chiave... da me. Piu' sicuro cosi'."	}
}

{
	Type	"convo"
	Descr	"Civilian"

	Sub	"NO10705A"	{	Text	"Oh!"	}
}

{
	Type	"convo"
	Descr	"Guard"

	Sub	"SG30705B"	{	Text	"Ehi! Chi va la'?"	}
}

{
	Type	"convo"
	Descr	"Civilian"

	Sub	"NO10705C"	{	Text	"Zotico! Mi hai quasi fatto morire di spavento!"	}
}

{
	Type	"convo"
	Descr	"Guard"

	Sub	"SG30705D"	{	Text	"Oh. Mi scusi, Signor Maron. Non sapevo che facesse tardi stasera."	}
}

{
	Type	"convo"
	Descr	"Civilian"

	Sub	"NO10705E"	{	Text	"Certo che faccio tardi, razza di... imbecille! (Sarcastico) Come altro dovrebbero essere finiti i documenti Rothchild? Con formule magiche?"	}
}

{
	Type	"convo"
	Descr	"Guard"

	Sub	"SG30705F"	{	Text	"Beh, signore, a-a noi non dicono gli orari dei banchieri che pagano per gli uffici secondari."	}
}

{
	Type	"convo"
	Descr	"Civilian"

	Sub	"NO10705G"	{	Text	"Oh... davvero? Molto affascinante. Ti prego... dimmi altri particolari... sui turni di guardia."	}
}

{
	Type	"convo"
	Descr	"Guard"

	Sub	"SG30705H"	{	Text	"Hmm. Beh, conosce le procedure per il cambio della guardia?"	}
}

{
	Type	"convo"
	Descr	"Civilian"

	Sub	"NO10705I"	{	Text	"Fuori dal mio ufficio!"	}
}

{
	Type	"convo"
	Descr	"Robot 1"

	Sub	"RB10706A"	{	Text	"Non lo so. E' vero che tu viaggi da questo luogo?"	}
}

{
	Type	"convo"
	Descr	"Robot 2"

	Sub	"RB10706B"	{	Text	"Si', Amico, ho un compito da svolgere."	}
}

{
	Type	"convo"
	Descr	"Robot 1"

	Sub	"RB10706C"	{	Text	"E' mio incarico... darti un avvertimento: ti prego di prestare attenzione... prima di viaggiare."	}
}

{
	Type	"convo"
	Descr	"Robot 2"

	Sub	"RB10706D"	{	Text	"Ho... udito. Come posso aiutarti... te?"	}
}

{
	Type	"convo"
	Descr	"Robot 1"

	Sub	"RB10706E"	{	Text	"Sappi che ho trovato... condizioni pericolose: un malfunzionamento."	}
}

{
	Type	"convo"
	Descr	"Robot 2"

	Sub	"RB10706F"	{	Text	"E' mio incarico... tornare a riparare se necessario... Non so... c'e'... un malfunzionamento."	}
}

{
	Type	"convo"
	Descr	"Robot 1"

	Sub	"RB10706G"	{	Text	"Laggiu', sotto questo luogo..."	}
}

{
	Type	"convo"
	Descr	"Robot 2"

	Sub	"RB10706H"	{	Text	"Compito da svolgere. Incontrero'... non altrettante... condizioni pericolose. Sia lodato Karras. Addio."	}
}

{
	Type	"convo"
	Descr	"Sheriff Truart"

	Sub	"M07WAX"	{	Text	"Ti servono soggetti per il tuo progetto Servant, e io posso fornirli. Vagabondi, feccia di strada, prostitute... gente che non manchera' a nessuno che conti."	}
}

