	Sub	"GAR0609"	{	Text	"Se riesco a trovare della cera morbida, posso prendere un'impronta della chiave e farne un duplicato piu' tardi."	}

	Sub	"GAR0610"	{	Text	"Huh. Chiave sbagliata."	}

	Sub	"GAR0611"	{	Text	"Questa e' la chiave giusta."	}

	Sub	"GAR0612"	{	Text	"Non era la chiave giusta."	}

	Sub	"GAR0613"	{	Text	"Meno male che posso ancora usare questa cera."	}

	Sub	"GAR0614"	{	Text	"No!"	}

	Sub	"GAR0615"	{	Text	"Spero che questo sia un posto sicuro dove lasciare questa chiave e farne una copia."	}

	Sub	"GAR0616"	{	Text	"Faro' meglio a tornare qui e rimettere questa chiave al suo posto quando avro' finito."	}

	Sub	"GAR0617"	{	Text	"Cosi' dovrebbe andare."	}

	Sub	"GAR0618"	{	Text	"Credo che qui il mio lavoro sia finito."	}
}

{
	Type	"convo"
	Descr	"Machinist 1"

	Sub	"MC10603A"	{	Text	"Che la peste lo colga! Non finiro' mai il mio progetto. Le molle e gli ingranaggi cospirano per confondermi."	}
}

{
	Type	"convo"
	Descr	"Machinist 2"

	Sub	"MC40603B"	{	Text	"Calma, Amico, calma... Domani passero' al tuo banco da lavoro e ti aiutero' a districare la faccenda."	}
}

{
	Type	"convo"
	Descr	"Machinist 1"

	Sub	"MC10603C"	{	Text	"T-te ne sarei molto grato. Potresti aiutarmi?"	}
}

{
	Type	"convo"
	Descr	"Machinist 2"

	Sub	"MC40603D"	{	Text	"Non e' nulla. Consideralo cosi': come rame e stagno si mescolano per formare il bronzo piu' forte, cosi' anche noi ci mescoliamo e scorriamo insieme nella forgia di Karras per diventare piu' forti."	}
}

{
	Type	"convo"
	Descr	"Machinist 1"

	Sub	"MC10603E"	{	Text	"Tu sei saggio."	}
}

{
	Type	"convo"
	Descr	"Machinist 2"

	Sub	"MC40603F"	{	Text	"E' Karras a essere davvero saggio. La sua munificenza, e le macchine che costruiamo, aiuteranno tutta l'umanita' nei tempi a venire, e tutti conosceranno la sua saggezza."	}
}

{
	Type	"convo"
	Descr	"Machinist 1"

	Sub	"MC10603G"	{	Text	"Saro' lieto di lasciarmi alle spalle questo misero compito per potermi spostare a una posizione piu' redditizia."	}
}

{
	Type	"convo"
	Descr	"Machinist 1"

	Sub	"MC30606A"	{	Text	"Te lo dico, poiche' sei mio amico: vorrei che i Figli di Karras sembrassero piu', ehm... miti."	}
}

{
	Type	"convo"
	Descr	"Machinist 2"

	Sub	"MC10606B"	{	Text	"Non sei il primo ad averne timore. Poiche' il loro volto e' forgiato per incutere terrore nei nemici di Karrasss... o... in coloro che potrebbero pensare di diventarlo."	}
}

{
	Type	"convo"
	Descr	"Machinist 1"

	Sub	"MC30606C"	{	Text	"Beh, potrebbe riuscirci. Poiche' quasi incute terrore nel mio stesso cuore."	}
}

{
	Type	"convo"
	Descr	"Machinist 2"

	MultiSub	"MC10606D"
	{
		{	Time	"0"	Length	"20000"	Text	"Pensi forse che il tuo tenero corpo di carne colante e gas ansimanti sia glorioso agli occhi del Builder? No! E' la tua anima l'unica cosa che abbia valore."	}
		{	Time	"15000"	Length	"15000"	Text	"Cosi' e' per i Figli di Karras, poiche' essi sono i benedetti e immortali eredi del Builder, mentre io e te non siamo che i miseri strumenti che li hanno forgiati."	}
	}
}

{
	Type	"convo"
	Descr	"Machinist 1"

	Sub	"MC30606E"	{	Text	"Come dici tu."	}
}

{
	Type	"convo"
	Descr	"Machinist 2"

	Sub	"MC10606F"	{	Text	"Che sciocco... Karras farebbe bene a liberarsi di quello."	}
}

{
	Type	"convo"
	Descr	"Machinist 1"

	Sub	"MC10607A"	{	Text	"Sai se lo sceriffo e' arrivato?"	}
}

{
	Type	"convo"
	Descr	"Machinist 2"

	Sub	"MC20607B"	{	Text	"Lo sceriffo? Che ci fa qui?"	}
}

{
	Type	"convo"
	Descr	"Machinist 1"

	Sub	"MC10607C"	{	Text	"Nel nome di Karras, uomo! Ti sei forse ficcato foglie nelle orecchie? Non hai sentito parlare della riunione?"	}
}

{
	Type	"convo"
	Descr	"Machinist 2"

	Sub	"MC20607D"	{	Text	"Oh... la riunione. Avevo... dimenticato che oggi fosse il giorno."	}
}

{
	Type	"convo"
	Descr	"Machinist 1"

	Sub	"MC10607E"	{	Text	"Pfaugh! Non hai idea di cio' di cui parlo. Devi imparare a prestare piu' attenzione, o ti ritroverai caduto lungo la via mentre il futuro ti passa accanto."	}
}

