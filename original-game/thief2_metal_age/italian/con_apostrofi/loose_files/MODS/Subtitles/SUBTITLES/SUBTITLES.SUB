	MultiSub	"KAR0609A"
	{
		{	Time	"2900"	Length	"10000"	Text	"(Servant che parla) Lasciatemi andare. Lasciatemi andare. Qualcuno mi liberi."	}
		{	Time	"9000"	Length	"15000"	Text	"(Karras che parla) Guarda, Sceriffo Truart! Dal basso marciume della strada emerge il lavoratore leale. Cio' che io chiamo... "Il Servant"."	}
		{	Time	"17200"	Length	"10000"	Text	"(Truart che parla) Questo e' uno dei vagabondi che ti ho consegnato? La trasformazione e' spettacolare!"	}
		{	Time	"22500"	Length	"8000"	Text	"(Karras che parla) E non ha ne' bisogno ne' preoccupazione alcuna."	}
		{	Time	"26200"	Length	"10000"	Text	"(Truart che parla) Beato lui! Strano che tu parli di preoccupazioni, Karras... perche' io ne ho una..."	}
	}

	MultiSub	"KAR0609B"
	{
		{	Time	"0"	Length	"10000"	Text	"(Truart che parla) Non e' che il denaro non sia giusto, no... e' solo che devo essere convinto che tu abbia preso le dovute precauzioni."	}
		{	Time	"6000"	Length	"10000"	Text	"Il nome dei Truart e' immacolato da scandali, e non saro' io a condurlo all'umiliazione e alla rovina."	}
		{	Time	"11200"	Length	"12000"	Text	"(Karras che parla) Abbi fede in me... poiche' e' il Builder Stesso a guidarmi. E il Barone... non dovra' mai saperlo."	}
		{	Time	"20200"	Length	"15000"	Text	"(Truart che parla) Si'... sono lieto che il tuo Builder ti guidi, ma mi sentirei ancora piu' sicuro se tu mi mettessi al corrente del tuo... intero piano."	}
	}

	MultiSub	"KAR0609C"
	{
		{	Time	"0"	Length	"10000"	Text	"(Truart che parla) Suvvia! Qual e' il nocciolo di tutto, eh, Karras? Mostrami che cos'hanno di tanto speciale i tuoi nuovi Servants."	}
		{	Time	"6000"	Length	"15000"	Text	"(Karras che parla) Ehm... impossibile celarti alcunche', buon Sceriffo. Ti daro' dunque una spiegazione completa sotto forma di... dimostrazione."	}
		{	Time	"16800"	Length	"15000"	Text	"La visione, in questo caso, supererebbe di gran lunga qualunque... elaborazione verbale io possa riferire. Ma devo chiederti di allontanarti dal Servant Mascherato. Proprio cosi'."	}
		{	Time	"28500"	Length	"15000"	Text	"E nel frattempo, andro' a recuperare il nostro... "volontario". Un disgraziatissimo monello di strada che attende appena fuori."	}
	}

	MultiSub	"KAR0609D"
	{
		{	Time	"2000"	Length	"12000"	Text	"(Karras che parla:) Vieni, vieni, gentile mendica. E fermati proooprio li', accanto all'uomo mascherato. Si'."	}
		{	Time	"10000"	Length	"10000"	Text	"Ora tutto e' pronto, dunque tieni gli occhi sul nuovo arrivato, mentre io invio il segnale al Servant... cosi'..."	}
	}

	MultiSub	"KAR0609E"
	{
		{	Time	"5500"	Length	"8000"	Text	"(Truart esclama:) Parola mia! La maschera emette un vapore rosso!"	}
		{	Time	"7000"	Length	"8000"	Text	"(Mendicante grida e poi urla:) Uh! Ti prego, no! Aiuto!"	}
		{	Time	"9000"	Length	"8000"	Text	"(Karras che parla:) Continua le tue osservazioni, Truart."	}
		{	Time	"11700"	Length	"8000"	Text	"(Truart esclama impaurito:) Ma li consuma! Siamo in pericolo!"	}
		{	Time	"14700"	Length	"12000"	Text	"(Karras che parla:) Non temere, saldo Sceriffo, poiche' a questa distanza siamo al sicuro. Vedi? Gia' la reazione cessa..."	}
	}

	MultiSub	"KAR0609F"
	{
		{	Time	"0"	Length	"10000"	Text	"(Truart esclama e osserva:) Sono spariti! E che cosa resta al loro posto? Sabbia? No... ruggine!"	}
		{	Time	"7000"	Length	"12000"	Text	"(Karras che parla:) Infatti, e' molto simile alla ruggine, e innocua una volta depositata. Fratello Feagan, ti prego, spazza via cio' che resta di quei due."	}
		{	Time	"17600"	Length	"4000"	Text	"(Feagan risponde:) Si'."	}
		{	Time	"19000"	Length	"15000"	Text	"(Truart esclama e osserva:) Un'arma, dunque! Davvero fantastico! E... mostruoso! Naturalmente, terrai questi Servants che stai creando lontani da me e dai miei uomini?"	}
		{	Time	"29500"	Length	"8000"	Text	"(Karras che parla:) Non hai nemmeno bisogno di chiederlo."	}
		{	Time	"31700"	Length	"8000"	Text	"(Truart che parla:) Allora siamo d'accordo!"	}
	}

	MultiSub	"KAR0609G"
	{
		{	Time	"0"	Length	"15000"	Text	"(Truart che parla, continua:) Ti servono soggetti per il tuo progetto Servant, e io posso fornirli. Vagabondi, feccia di strada, prostitute... gente che non manchera' a nessuno che conti."	}
		{	Time	"10000"	Length	"15000"	Text	"Verranno rastrellati, inventeremo delle accuse, eccetera. Comunque, c'e' sempre un rischio. Quindi te ne daro'... venti, non di piu'. Da parte tua, ricorderai di mantenere le nostre transazioni assolutamente segrete!"	}
		{	Time	"23000"	Length	"15000"	Text	"E naturalmente consegnerai il mio pagamento, in anticipo e per intero, domani. Non mi fido di te, Karras, quindi riceverai i soggetti solo dopo che avro' confermato il pagamento."	}
	}

	MultiSub	"KAR0609H"
	{
		{	Time	"0"	Length	"10000"	Text	"(Truart che parla, continua:) Bene, i nostri affari qui sono conclusi."	}
		{	Time	"5500"	Length	"10000"	Text	"(Karras che parla:) Si'i'i'... Va' in pace, Truart!"	}
	}

	MultiSub	"KAR0610A"
	{
		{	Time	"0"	Length	"20000"	Text	"(Karras che parla:) Ora vedete, amici... con l'efficienza del Builder ho completato due compiti con un solo... sforzo. Primo, ho assicurato venti soggetti da trasformare in Servants, come avete udito."	}
		{	Time	"16000"	Length	"15000"	Text	"E secondo, ho assicurato la lealta' del diffidente Sceriffo Truart. Si'... la sua lealta'... heh."	}
		{	Time	"25000"	Length	"12000"	Text	"Truart teme lo scandalo. Eppure le sue azioni recenti potrebbero portargli proprio quello, o peggio, se mai venissero rese pubbliche."	}
	}

	MultiSub	"KAR0610S"
	{
		{	Time	"0"	Length	"20000"	Text	"Ora, osservate la mia macchina a cilindro di cera. L'ho usata per catturare le parole stesse dello Sceriffo, persino mentre attraversavano l'aria, oggi. Ascoltate, amici!"	}
		{	Time	"15500"	Length	"15000"	Text	"(Registrazione delle parole di Truart:) ...E io posso fornirli. Vagabondi, feccia di strada, prostitute... gente che non manchera' a nessuno che conti..."	}
		{	Time	"24000"	Length	"15000"	Text	"(Karras che parla:) Con la sua voce cosi' preservata, Truart non osera' tradirmi, o avra' lo scandalo che teme tanto."	}
		{	Time	"33500"	Length	"15000"	Text	"Fratello Feagan. Farai in modo che questa macchina a cilindro di cera arrivi sana e salva alla banca domani."	}
	}
}

