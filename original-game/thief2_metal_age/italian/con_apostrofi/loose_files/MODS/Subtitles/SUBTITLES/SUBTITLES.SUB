{
	Type	"bark"
	Descr	"Machinist"

	Sub	"MC4A0CH1"	{	Text	"Io sono diligente; fu il Builder a farmi cosi'. Io sono instancabile; fu il Builder a farmi cosi'."	}

	Sub	"MC4A0CH2"	{	Text	"O Builder, alimentami! O Karras, alimentami! Poiche' io sono il vostro servitore e compio la Vostra volonta', ora... e per sempre."	}

	Sub	"MC4A0CH3"	{	Text	"Se vi e' una giuntura, saldala. Se vi e' un ingranaggio, giralo. Se vi e' una fornace, alimentala."	}

	Sub	"MC4A0CH4"	{	Text	"Se vi e' un albero, abbattilo. Se vi e' un lupo, macellalo. Se vi e' un Eretico, non tollerare che viva oltre."	}

	Sub	"MC4A0CH5"	{	Text	"E Karras parlo', dicendo: "Io sono la ruota e voi siete gli ingranaggi! Senza la ruota gli ingranaggi non hanno scopo, e senza gli ingranaggi la ruota non ha denti." Cosi' parlo' Karras."	}

	Sub	"MC4A0CH6"	{	Text	"La foresta e' oscura. Karras sia la mia luce! La caverna e' oscura. Karras sia la mia luce! La notte e' oscurita' traditrice. Karras sia la mia grande e sempre splendente luce!"	}

	Sub	"MC4A0CH7"	{	Text	"Io sono diligente; fu il Builder a farmi cosi'. Io sono instancabile; fu il Builder a farmi cosi'."	}

	Sub	"MC4A0CH8"	{	Text	"O Builder, alimentami! O Karras, alimentami! Poiche' io sono il vostro servitore e compio la Vostra volonta', ora... e per sempre."	}

	Sub	"MC4A0CH9"	{	Text	"Se vi e' un Eretico, non tollerare che viva oltre."	}

	Sub	"MC4A0CHA"	{	Text	"E Karras parlo', dicendo: "Io sono la ruota e voi siete gli ingranaggi! Senza la ruota gli ingranaggi non hanno scopo, e senza gli ingranaggi la ruota non ha denti." Cosi' parlo' Karras."	}

	Sub	"MC4A0CHB"	{	Text	"La foresta e' oscura. Karras sia la mia luce! La caverna e' oscura. Karras sia la mia luce! La notte e' oscurita' traditrice. Karras sia la mia grande e sempre splendente luce!"	}

	Sub	"MC4A0MU2"	{	Text	"...ma-sono cosi' stanco... m-non finiro' mai questa cosa... il vino non mi ha fatto granche'..."	}

	Sub	"MC4A0MU3"	{	Text	"Hmm-che faro'? Perche' sto--? Beh, come faro' a farlo?.. No... nooo... que-que-questo... Tipo--no, non lo ero--no, non lo ero..."	}
}

{
	Type	"urgent"
	Descr	"Machinist"

	Sub	"MC4A1__1"	{	Text	"Pronto?"	}

	Sub	"MC4A1__2"	{	Text	"Sei li'?"	}

	Sub	"MC4A1__3"	{	Text	"Per amor del Builder, cos'e' stato?"	}

	Sub	"MC4A1__4"	{	Text	"Buon ingranaggio, sei tu?"	}

	Sub	"MC4A1_W1"	{	Text	"Parla, Amico! Hai notato guai?"	}

	Sub	"MC4A1H_1"	{	Text	"I miei timpani... battono molto oggi."	}

	Sub	"MC4A1H_2"	{	Text	"Sara' meglio che siano ratti quelli che sento laggiu'!"	}

	Sub	"MC4A1HW1"	{	Text	"Sta' quieto, buon ingranaggio, mentre ascolto questo rumore!"	}

	Sub	"MC4A1HW2"	{	Text	"Proprio allora! L'hai udito anche tu?"	}

	Sub	"MC4A1HW3"	{	Text	"Shhh! Ho udito... qualcosa."	}

	Sub	"MC4A1V_1"	{	Text	"Hmmm... cos'e' quello?"	}

	Sub	"MC4A1VW1"	{	Text	"La'!.. L'hai visto?"	}

	Sub	"MC4A1VW2"	{	Text	"Per un momento, ho creduto di vedere qualcosa!"	}

	Sub	"MC4A1VW3"	{	Text	"Amico, hai visto quello?"	}

	Sub	"MC4A2__1"	{	Text	"Ehi! Mostrati subito!"	}

	Sub	"MC4A2__2"	{	Text	"Per il Builder, rivelati!"	}

	Sub	"MC4A2__3"	{	Text	"Chi turba la mia guardia? Parla ora!"	}

	Sub	"MC4A2__4"	{	Text	"Chiunque tu sia, fatti avanti!"	}

	Sub	"MC4A2H_1"	{	Text	"Ti odo gracchiare, rospo! Fatti vedere!"	}

	Sub	"MC4A2H_2"	{	Text	"Chi fa quel rumore? Rivelati!"	}

	Sub	"MC4A2SE1"	{	Text	"Ascolta! Posso udire il tuo respiro tremante!"	}

	Sub	"MC4A2SE2"	{	Text	"Il Builder mi guidera' a te... erbaccia!"	}

	Sub	"MC4A2SE3"	{	Text	"Esci dalle ombre!"	}

	Sub	"MC4A2SE4"	{	Text	"Builder, aiutami a trovare questa minaccia!"	}

	Sub	"MC4A2V_1"	{	Text	"Ti ho visto, erbaccia! Ora fatti avanti allo scoperto!"	}

	Sub	"MC4A3__1"	{	Text	"Ehi!"	}

	Sub	"MC4A3__2"	{	Text	"A-ha!"	}

	Sub	"MC4A3B_1"	{	Text	"Omicidio! Un assassino!"	}

	Sub	"MC4A3B_2"	{	Text	"Il Builder non tollera simili malefatte! Assassino!"	}

	Sub	"MC4A3NA1"	{	Text	"Alt, erbaccia! Lascia cadere l'arma!"	}

	Sub	"MC4A3NA2"	{	Text	"Fermo! Sei preso, ladro."	}

	Sub	"MC4A3NA3"	{	Text	"Alt! Lascia cadere l'arma, vile erbaccia!"	}

	Sub	"MC4A3NA4"	{	Text	"I tuoi piedi saranno presto sradicati!"	}

	Sub	"MC4A3S_1"	{	Text	"Un farabutto appare dinanzi a me!"	}

	Sub	"MC4A3S_2"	{	Text	"Per il Builder, sei stato scorto!"	}

	Sub	"MC4A3S_3"	{	Text	"A-ha! Un'erbaccia e' germogliata!"	}

	Sub	"MC4A3S_4"	{	Text	"Ora sei preso, intruso!"	}

	Sub	"MC4A3SE1"	{	Text	"Stanne certo, ladro! Ti trovero'!"	}

	Sub	"MC4A3SE2"	{	Text	"Nasconditi se puoi, farabutto! Ti scorgero' abbastanza presto!"	}

	Sub	"MC4A3SE3"	{	Text	"Builder! Karras! Guidatemi all'infedele!"	}

	Sub	"MC4A3SE4"	{	Text	"Solo i codardi si nascondono cosi', farabutto!"	}

	Sub	"MC4ALMA1"	{	Text	"Suonero' l'allarme, sara' il suono della tua... rovina, farabutto!"	}

	Sub	"MC4ALMA2"	{	Text	"Con questo allarme suggello il tuo destino!"	}

	Sub	"MC4ALMW1"	{	Text	"Presto! Andate ora e fate suonare gli allarmi!"	}

	Sub	"MC4AMB_1"	{	Text	"Maledizione a tutto! Chi e' stato?"	}

	Sub	"MC4AMB_2"	{	Text	"Ah! Vieni fuori e riprovaci!"	}

	Sub	"MC4AMB_3"	{	Text	"Ehi! Quale ombra mi ha colpito?"	}

	Sub	"MC4AMB_4"	{	Text	"Da dove e' venuto?"	}

	Sub	"MC4AMBW1"	{	Text	"Hai visto cosa mi ha colpito, Amico?"	}

	Sub	"MC4AMBW2"	{	Text	"Ah! Sono assalito... Vedi forse un nemico?"	}

	Sub	"MC4AMBW3"	{	Text	"Che danno e' questo, Amico?"	}

	Sub	"MC4ATB_1"	{	Text	"Karras acceleri il mio dardo verso di te!"	}

	Sub	"MC4ATB_2"	{	Text	"Cadi sotto il mio dardo!"	}

	Sub	"MC4ATB_3"	{	Text	"Hah! Sei trafitto!"	}

	Sub	"MC4ATL_1"	{	Text	"Aiutami, Grande Builder!"	}

	Sub	"MC4ATL_2"	{	Text	"Karras, non abbandonarmi!"	}

	Sub	"MC4ATN_1"	{	Text	"Porro' fine alle tue vie peccaminose!"	}

	Sub	"MC4ATN_2"	{	Text	"Questo ti fermera', ladro!"	}

	Sub	"MC4ATN_6"	{	Text	"Sei abbattuto, albero!"	}

	Sub	"MC4ATN_7"	{	Text	"Vediamo come sanguini!"	}

	Sub	"MC4ATN_8"	{	Text	"I tuoi giorni peccaminosi sono finiti!"	}

	Sub	"MC4ATN_9"	{	Text	"Io sono la mano del Builder!"	}

	Sub	"MC4ATS_1"	{	Text	"Builder... abbattilo!"	}

	Sub	"MC4ATS_2"	{	Text	"Il mio arco ti abbattera'!"	}

	Sub	"MC4ATW_1"	{	Text	"Ha-mi aspettavo un combattimento migliore, ladro!"	}

	Sub	"MC4ATW_2"	{	Text	"Gia' ti sgretoli, rospo viscido?"	}

	Sub	"MC4ATWW1"	{	Text	"Vedete come si sgretola?"	}

	Sub	"MC4BAK_1"	{	Text	"Il vento e' inquieto questa notte."	}

	Sub	"MC4BAK_2"	{	Text	"Non erano ratti, di questo sono certo. Non nella casa del Builder!"	}

	Sub	"MC4BAK_3"	{	Text	"Probabilmente non era nulla... Probabilmente."	}

	Sub	"MC4BAK_4"	{	Text	"Il Builder mostrera' tutto, se e' destinato a essere rivelato."	}

	Sub	"MC4BAK_5"	{	Text	"Se erano ratti, allora non sono lieto, poiche' sono creature miserabili!"	}

	Sub	"MC4BAK_6"	{	Text	"L'Amico Enoch disse di passare al te', ma l'ho fatto? Heh. E ora i miei nervi sono del tutto logori!"	}

	Sub	"MC4BAK_7"	{	Text	"E' di nuovo il silenzio del Builder. Per questo... sono grato!"	}

	Sub	"MC4BAK_8"	{	Text	"Per Karras, lo giuro, pensavo che qualcosa non andasse!"	}

	Sub	"MC4BKD_1"	{	Text	"La prossima volta trovero' il segno, farabutto!"	}

	Sub	"MC4BKD_2"	{	Text	"Karras, fa' che il mio prossimo colpo sia saldo!"	}

	Sub	"MC4BKD_3"	{	Text	"Non pararmi! La morte ti attende!"	}

	Sub	"MC4BKDW1"	{	Text	"Non riesco a raggiungerlo, Amico!"	}

	Sub	"MC4BLK_1"	{	Text	"Combatti come un mazzo di margherite!"	}

	Sub	"MC4BLK_2"	{	Text	"Devi impegnarti piu' di cosi' per battermi!"	}

	Sub	"MC4BLK_3"	{	Text	"Sei troppo lento, farabutto!"	}

	Sub	"MC4BLKW1"	{	Text	"Vedi, Amico, come il Builder mi aiuta?"	}

	Sub	"MC4BOD_1"	{	Text	"No!.. No! Omicidio crudelissimo! Builder ci protegga tutti!"	}

	Sub	"MC4BOD_2"	{	Text	"Che male e' questo? Omicidio, nella casa del Builder?"	}

	Sub	"MC4BOD_3"	{	Text	"Oh no! Ti vendichero', Amico caduto!"	}

	Sub	"MC4CHGA1"	{	Text	"Sono alimentato dai fuochi del Builder, Egli stesso!"	}

	Sub	"MC4CHGA2"	{	Text	"Preparati al tuo calpestamento, erbaccia!"	}

	Sub	"MC4CHGA3"	{	Text	"Sei condannato!"	}

	Sub	"MC4CHGW1"	{	Text	"Vieni, Amico, schiacciamo questo rospo!"	}

	Sub	"MC4CHGW2"	{	Text	"Non lasciarlo fuggire!"	}

	Sub	"MC4CHGW3"	{	Text	"Noi siamo la sua rovina!"	}

	Sub	"MC4DET_1"	{	Text	"Non temere! La tua morte sara' rapida!"	}

	Sub	"MC4DET_2"	{	Text	"E' tempo di salutare il Builder!"	}

	Sub	"MC4DET_3"	{	Text	"Non puoi ritardare l'inevitabile!"	}

	Sub	"MC4DETW1"	{	Text	"Non potra' parare i colpi di entrambi, eh?"	}

	Sub	"MC4DIEC3"	{	Text	"Builder... prendimi..."	}

	Sub	"MC4FRUS1"	{	Text	"Ti prenderemo, prima o poi!"	}

	Sub	"MC4FRUS2"	{	Text	"Puoi sfuggirci per ora, ma la morte ti attende!"	}

