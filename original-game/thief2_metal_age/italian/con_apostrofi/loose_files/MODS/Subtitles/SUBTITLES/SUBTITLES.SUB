{
	Type	"bark"
	Descr	"Haunt"

	Sub	"HH1A0MO1"	{	Text	"Le tue parole hanno colpito come lance... a fondo tra pensieri insanguinati e oscuri. Devi spazzare i tuoi pavimenti, mondandoli di vergogna e sangue."	}

	Sub	"HH1A0MO2"	{	Text	"Bisogna prestare cura quando si lavora tra gli interruttori, e badare a tenere le fondamenta lontane dalle fiamme."	}

	Sub	"HH1A0MO3"	{	Text	"Cosi' devi armarti contro i (due voci insieme) malvagi nella notte (due voci insieme). Come tu dici; le vipere abbondano, contorcendosi nella corruzione e nell'incredulita'."	}

	Sub	"HH1A0WH1"	{	Text	"Cosi' devi armarti contro i (due voci insieme) malvagi nella notte (due voci insieme). Come tu dici; le vipere abbondano, contorcendosi nella corruzione e nell'incredulita'."	}

	Sub	"HH1A0WH2"	{	Text	"Bisogna prestare cura quando si lavora tra gli interruttori, e badare a tenere le fondamenta lontane dalle fiamme."	}

	Sub	"HH1A0WH3"	{	Text	"Le tue parole hanno colpito come lance... a fondo tra pensieri insanguinati e oscuri. Devi spazzare i tuoi pavimenti, mondandoli di vergogna e sangue."	}
}

{
	Type	"urgent"
	Descr	"Haunts"

	Sub	"HH1A1__1"	{	Text	"Unisciti a noi, Gaaarrett!"	}

	Sub	"HH1A1__2"	{	Text	"Soffrirai giorni e secoli di demoni... e morirai!"	}

	Sub	"HH1A1__3"	{	Text	"Fabbro, torna alle tue fiamme."	}

	Sub	"HH1A1__4"	{	Text	"Fiamme intorno a te, fiamme, nient'altro che fiamme; che bruciano la tua carne."	}

	Sub	"HH1A1__5"	{	Text	"La tua anima non puo' essere salvata."	}

	Sub	"HH1A1__6"	{	Text	"Unisciti a noi, unisciti a noi, unisciti a noi ora!"	}

	Sub	"hh1bak__1"	{	Text	"Un'occasione di sangue..."	}

	Sub	"HH1TO1_1"	{	Text	"Chiiii?"	}
}

