{
	Type	"player"
	Descr	"Garrett"

	Sub	"GAR0401"	{	Text	"Dovrei dare un'occhiata a quelle istruzioni."	}

	Sub	"GAR0402"	{	Text	"Oooh si'... se n'e' andato."	}

	Sub	"GAR0403"	{	Text	"Non ne avra' piu' bisogno."	}

	Sub	"GAR0404"	{	Text	"Davvero raffinato. Immagino che essere un ufficiale renda bene."	}

	Sub	"GAR0405"	{	Text	"Bella vista."	}

	Sub	"GAR0406"	{	Text	"Ora... al caveau."	}

	Sub	"GAR0407"	{	Text	"Pare che questa Mosley abbia un debole per le piante. Beh, immagino che possa permetterselo."	}

	Sub	"GAR0408"	{	Text	"Vediamo che cosa posso usare contro il nostro Tenente Hagen."	}

	Sub	"GAR0409"	{	Text	"Immagino che un po' di tiro al bersaglio non mi faccia male."	}

	Sub	"GAR0410"	{	Text	"Dovrei riuscire a trovare qualcosa qui dentro."	}

	Sub	"GAR0411"	{	Text	"Mechanists, sempre a fare i benefattori."	}

	Sub	"GAR0412"	{	Text	"Meglio fare in fretta."	}

	Sub	"GAR0413"	{	Text	"Lasciarli uscire rovinerebbe il piano."	}

	Sub	"GAR0414"	{	Text	"Non credo di voler passare di li'."	}

	Sub	"GAR0415"	{	Text	"Hagen non sembra troppo... entusiasta del Tenente Mosley, vero?"	}

	Sub	"GAR0416"	{	Text	"Dovrei fare attenzione qui dentro. Probabilmente ci sono alcune trappole in giro."	}

	Sub	"GAR0417"	{	Text	"Ehi! So chi e' questo tizio."	}

	Sub	"GAR0418"	{	Text	"No, grazie. Non ho mai cosi' tanta fame."	}

	MultiSub	"GAR0419"
	{
		{	Time	"0"	Length	"4100"	Text	"Dovrei annotarmelo..."	}
		{	Time	"4200"	Length	"5000"	Text	"[pausa] Ora... al caveau."	}
	}

	Sub	"GAR0420"	{	Text	"Beh, qui si sta stretti."	}

	Sub	"GAR0421"	{	Text	"Si', certo. La vita e' dura quando non hai nessuno che ti serva di tutto punto."	}

	Sub	"GAR9902"	{	Text	"Devo trovare un modo migliore di questo."	}

	Sub	"GAR9911"	{	Text	"E' ora di andare..."	}

	Sub	"GAR9919"	{	Text	"Non posso restare sott'acqua troppo a lungo, o anneghero'!"	}

	Sub	"GAR9920"	{	Text	"Huh... Non e' piu' tanto segreto, vero?"	}

	Sub	"GAR9922"	{	Text	"Ahh, una porta sul retro."	}

	Sub	"GAR9927"	{	Text	"Questa sembra la via d'ingresso."	}

	Sub	"GAR9928"	{	Text	"Aaah. Un ingresso nascosto."	}

	Sub	"GAR9930"	{	Text	"Ahhh... il mio anno preferito!"	}
}

{
	Type	"convo"
	Descr	"Thief"

	Sub	"TH10402A"	{	Text	"Non potete trattarmi cosi'! Sono un vet'rano!"	}
}

{
	Type	"convo"
	Descr	"Guard"

	Sub	"SG60402B"	{	Text	"Gia', scommetto che e' li' che hai imparato a borseggiare cosi' bene."	}
}

{
	Type	"convo"
	Descr	"Thief"

	Sub	"TH10402C"	{	Text	"Q-q-q--quando sono tornato, la mia famiglia era sparita. N-non avevo soldi per vivere."	}
}

{
	Type	"convo"
	Descr	"Guard"

	Sub	"SG60402D"	{	Text	"Certo. Raccontalo allo sceriffo. Ha un debole speciale per gli eroi di guerra."	}
}

{
	Type	"convo"
	Descr	"Guard"

	Sub	"SG40404A"	{	Text	"D'accordo... Ricominciamo dall'inizio: che cosa e' successo?"	}
}

{
	Type	"convo"
	Descr	"Lady Rumford"

	MultiSub	"NO20404B"
	{
		{	Time	"0"	Length	"8000"	Text	"Beh... la mia serva, Jenivere, e' scomparsa. Ora, non aveva alcun motivo di scappare..."	}
		{	Time	"5000"	Length	"8000"	Text	"L'ho trattata come una figlia... chi si prendera' cura di me adesso?"	}
	}
}

{
	Type	"convo"
	Descr	"Guard"

	Sub	"SG40404C"	{	Text	"Signora... mi spiace interromperla, ma sta divagando di nuovo. Si attenga ai fatti, per favore."	}
}

{
	Type	"convo"
	Descr	"Lady Rumford"

	MultiSub	"NO20404D"
	{
		{	Time	"0"	Length	"8000"	Text	"Avete intenzione di aiutarmi oppure no? Sappiate che sono un'amica personale di Padre Karras."	}
		{	Time	"6000"	Length	"8000"	Text	"Ha una grande influenza, sapete. Da dove credete che arrivino tutti i vostri nuovi congegni eleganti?"	}
		{	Time	"12000"	Length	"8000"	Text	"Dubito che sarebbe lieto di sapere che state trascurando di aiutare una sua amica..."	}
	}
}

{
	Type	"convo"
	Descr	"Guard"

	MultiSub	"SG40404E"
	{
		{	Time	"0"	Length	"8000"	Text	"Mi scusi, signora. Sto solo cercando di venire a capo del suo problema il piu' in fretta possibile."	}
		{	Time	"4500"	Length	"8000"	Text	"Prima finiamo qui, prima potremo iniziare a cercare la sua serva."	}
		{	Time	"8000"	Length	"8000"	Text	"Perche' non si calma e si ricompone, mentre io ricapitolo cio' che abbiamo finora?"	}
	}
}

{
	Type	"convo"
	Descr	"Lady Rumford"

	Sub	"NO20404F"	{	Text	"Uh-h... Mi dispiace, Agente... Grazie."	}
}

{
	Type	"convo"
	Descr	"Guard 1"

	Sub	"SG30406A"	{	Text	"Com'e' che dobbiamo fare noi il turno di guardia? I Mechanists non potevano mettere altri di quegli occhi meccani-- mecca-- meccanici in giro?"	}
}

{
	Type	"convo"
	Descr	"Guard 2"

	Sub	"SG10406B"	{	Text	"Perche' noi non possiamo essere spenti con la stessa facilita', taffer."	}
}

{
	Type	"convo"
	Descr	"Guard 1"

	Sub	"SG30406C"	{	Text	"Oooh... Almeno e' meglio che montare la guardia per i Downwinders."	}
}

{
	Type	"convo"
	Descr	"Guard 2"

	Sub	"SG10406D"	{	Text	"Maledettamente vero. Niente puzza di fogna, niente muffa, meno ratti."	}
}

{
	Type	"convo"
	Descr	"Guard 1"

	Sub	"SG30406E"	{	Text	"Ti sei mai ch-chiesto perche' Truart ci ha assunti?"	}
}

{
	Type	"convo"
	Descr	"Guard 2"

	MultiSub	"SG10406F"
	{
		{	Time	"0"	Length	"8000"	Text	"Non proprio. Probabilmente ha pensato che avremmo passato meno tempo a infrangere la legge, visto che dovevamo farla rispettare."	}
		{	Time	"5000"	Length	"8000"	Text	"L'oro e' oro, non importa se viene da Reuben o dallo Sceriffo Truart."	}
	}
}

{
	Type	"convo"
	Descr	"Machinist"

	Sub	"MC10407A"	{	Text	"Il Watcher e' pronto e operativo. Ora, che attivi l'allarme ogniqualvolta un intruso s'avvicini."	}
}

{
	Type	"convo"
	Descr	"Guard"

	Sub	"SG50407B"	{	Text	"Come fa a capire la differenza tra noi e un intruso?"	}
}

{
	Type	"convo"
	Descr	"Machinist"

	Sub	"MC10407C"	{	Text	"Per trovare risposta a tale domanda, devi frequentare il Seminario Mechanist e unirti al nostro Ordine. La saggezza di Karras non e' per gli occhi dell'uomo "comune"."	}
}

{
	Type	"convo"
	Descr	"Guard"

	Sub	"SG50407D"	{	Text	"E la manutenzione di tutti questi marchingegni?"	}
}

{
	Type	"convo"
	Descr	"Machinist"

	MultiSub	"MC10407E"
	{
