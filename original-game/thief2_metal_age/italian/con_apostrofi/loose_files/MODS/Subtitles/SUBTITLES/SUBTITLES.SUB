{
	Type	"bark"
	Descr	"Machinist"

	Sub	"MC2A0CH1"	{	Text	"E Karras disse: ''Deponete il vostro martello, amici, sono orpelli dell'anno passato!'' E cosi' li deponemmo, e vedendo cio', Karras parlo' ancora: ''Ora levate la vostra mazza, il Builder vi alimentera'... e tutti i seguaci di Karras.''"	}

	Sub	"MC2A0CH2"	{	Text	"Il pistone collegato alla valvola a spirale, la valvola a spirale collegata all'ingranaggio a gradini, l'ingranaggio a gradini collegato al martinetto a vapore. O! ascolta, tu, la parola di Karras!"	}

	Sub	"MC2A0CH3"	{	Text	"Ieri costruii la mia casa di mattoni e pietra. Una dimora infantile per tempi infantili! Ora sono un uomo e ho costruito la mia casa di ferro e acciaio. Sia benedetto il Builder per questo e per tutti i Suoi doni!"	}

	Sub	"MC2A0CH4"	{	Text	"O misera selva, assediata da strisciamenti, maledetta sopra ogni luogo, non trovare la via nei miei soggiorni notturni, non attaccare i tuoi turpi abitanti ai miei sogni."	}

	Sub	"MC2A0CH5"	{	Text	"E venne un bue e Karras lo abbatte'. E venne un sicomoro ed egli fece piovere colpi finche' anch'esso fu duramente abbattuto. E vennero due agnellini, che egli, l'uno e poi l'altro, abbatte' con coraggio e perizia."	}

	Sub	"MC2A0CH6"	{	Text	"E Karras disse: ''Udite, il fruscio delle foglie, levatevi e abbattete gli alberi!''. In verita' menammo fendenti e sanguinammo, ecco! finche' l'ultimo castagno fuggi', e allora ci inginocchiammo e piangemmo i morti."	}

	Sub	"MC2A0CH7"	{	Text	"O misera selva, assediata da strisciamenti, maledetta sopra ogni luogo, non trovare la via nei miei soggiorni notturni, non attaccare i tuoi turpi abitanti ai miei sogni."	}
}

{
	Type	"urgent"
	Descr	"Machinist"

	Sub	"MC2A1__1"	{	Text	"Chi cammina la'?"	}

	Sub	"MC2A1__2"	{	Text	"Quale rumore la' chiama piano?"	}

	Sub	"MC2A1__3"	{	Text	"Quale libellula svolazza in giro?"	}

	Sub	"MC2A1__4"	{	Text	"Chi c'e'? Chi va la'?"	}

	Sub	"MC2A1_W1"	{	Text	"Ehi... hai notato qualcosa che non va?"	}

	Sub	"MC2A1H_1"	{	Text	"Ma piano, fu un rumore cio' che udii!"	}

	Sub	"MC2A1H_2"	{	Text	"Chi c'e'? Quale rumore fai?"	}

	Sub	"MC2A1HW1"	{	Text	"Silenzio un poco! Io... ho udito un rumore."	}

	Sub	"MC2A1HW2"	{	Text	"Ascolta! L'hai udito? Un suono!"	}

	Sub	"MC2A1HW3"	{	Text	"Buon ingranaggio, ascolta con me... Cos'e' stato quel rumore?"	}

	Sub	"MC2A1V_1"	{	Text	"Si e' forse mossa quell'ombra?"	}

	Sub	"MC2A1VW1"	{	Text	"Devo fidarmi della mia vista, Amico, o tu non hai veduto nulla?"	}

	Sub	"MC2A1VW2"	{	Text	"Guarda attentamente la', Amico! Hai forse veduto giusto?"	}

	Sub	"MC2A1VW3"	{	Text	"Ho scorto qualcosa, credo!"	}

	Sub	"MC2A2__1"	{	Text	"Per Karras, non avro' alcun misfatto durante il mio turno!"	}

	Sub	"MC2A2__2"	{	Text	"Le mie istruzioni sono chiare: nessuno... dovra'... passare!"	}

	Sub	"MC2A2__3"	{	Text	"Sono pronto per te! Sei forse li'?"	}

	Sub	"MC2A2__4"	{	Text	"Chi turba la mia guardia? Mostrati!"	}

	Sub	"MC2A2H_1"	{	Text	"Cessa i tuoi svolazzamenti e mostrati!"	}

	Sub	"MC2A2H_2"	{	Text	"Naaahaa! Sei preso! Vieni nella luce!"	}

	Sub	"MC2A2SE1"	{	Text	"Ho dalla mia parte la Pazienza del Builder!"	}

	Sub	"MC2A2SE2"	{	Text	"Solo i codardi, e le erbacce piu' vili, si nascondono cosi'..."	}

	Sub	"MC2A2SE3"	{	Text	"Sollevero' ogni pietra finche' non ti trovero', salamandra!"	}

	Sub	"MC2A2SE4"	{	Text	"Rivelati e arrenditi!"	}

	Sub	"MC2A2V_1"	{	Text	"Sei stato scorto! Chi sei, farabutto?"	}

	Sub	"MC2A3__2"	{	Text	"Cos'e' questo?"	}

	Sub	"MC2A3B_1"	{	Text	"Cos'e' questo? Omicidio? Amici! A me!"	}

	Sub	"MC2A3B_2"	{	Text	"Vile criminale! Assassino! Preparati ai giudizi del Builder!"	}

	Sub	"MC2A3NA1"	{	Text	"La tua testa... e' pronta per la mia mazza?"	}

	Sub	"MC2A3NA2"	{	Text	"Ahaa! Accolgo il combattimento. Preparati!"	}

	Sub	"MC2A3NA3"	{	Text	"Sei rivelato, nemico! Difenditi!"	}

	Sub	"MC2A3S_1"	{	Text	"Fermo! In nome di Karras... fermo!"	}

	Sub	"MC2A3S_2"	{	Text	"Fermati! Non compiere, tu, alcuna altra azione!"	}

	Sub	"MC2A3S_3"	{	Text	"Alt, erbaccia! Non sei il benvenuto qui!"	}

	Sub	"MC2A3SE1"	{	Text	"Ti abbattero', quando ti trovero'!"	}

	Sub	"MC2A3SE2"	{	Text	"Ho trovato nemici nascosti meglio di te!"	}

	Sub	"MC2A3SE3"	{	Text	"E' un gioco da codardi quello che fai!"	}

	Sub	"MC2A3SE4"	{	Text	"Il tuo fetore malvagio ti fara' uscire dal nascondiglio!"	}

	Sub	"MC2ALMA1"	{	Text	"C'e' un ladro! Date l'allarme!"	}

	Sub	"MC2ALMA2"	{	Text	"Vado agli allarmi! Guai a te, ladro!"	}

	Sub	"MC2ALMA3"	{	Text	"Date gli allarmi! Fateli risuonare!"	}

	Sub	"MC2ALMW1"	{	Text	"Va' all'allarme! Io affrontero' il nemico!"	}

	Sub	"MC2AMB_1"	{	Text	"Ah! Sono colpito lievemente! Chi osa?"	}

	Sub	"MC2AMB_2"	{	Text	"Ah! Temi forse la mazza? Bene cosi', poiche' dovresti!"	}

	Sub	"MC2AMB_3"	{	Text	"Ugh! Vieni fuori, codardo, e prova di nuovo il tuo attacco!"	}

	Sub	"MC2AMB_4"	{	Text	"Mmhrr!... Hai destato la mia ira, strisciante d'ombra!!"	}

	Sub	"MC2AMBW1"	{	Text	"Sono assediato! Vedi, tu, il mio nemico?"	}

	Sub	"MC2AMBW2"	{	Text	"Aiuto, Amico! Quale sorta di nemico mi ha assalito?"	}

	Sub	"MC2AMBW3"	{	Text	"Uhh! Vedi, tu, chi mi priva di combustibile! Sono colpito!"	}

	Sub	"MC2ATB_1"	{	Text	"Il mio dardo ti scucira'!"	}

	Sub	"MC2ATB_2"	{	Text	"Assaggia il duro ferro, ladro!"	}

	Sub	"MC2ATB_3"	{	Text	"La mia mira e' sicura!"	}

	Sub	"MC2ATL_1"	{	Text	"Presta aiuto, buon Karras!"	}

	Sub	"MC2ATL_2"	{	Text	"Karras! Alimentami!"	}

	Sub	"MC2ATN_1"	{	Text	"I tuoi giorni di peccato finiscono ora, farabutto!"	}

	Sub	"MC2ATN_2"	{	Text	"Mazza, trova il tuo bersaglio!"	}

	Sub	"MC2ATN_6"	{	Text	"Ti sradico, erbaccia!"	}

	Sub	"MC2ATN_7"	{	Text	"Gracida, rospo traditore!"	}

	Sub	"MC2ATN_8"	{	Text	"Sei finito!"	}

	Sub	"MC2ATN_9"	{	Text	"Come cadono gli ingiusti!"	}

	Sub	"MC2ATN_A"	{	Text	"Sei certamente abbattuto!"	}

	Sub	"MC2ATS_1"	{	Text	"Dal pugno del Builder al tuo cuore!"	}

	Sub	"MC2ATS_2"	{	Text	"Karras, guida il mio potere!"	}

	Sub	"MC2ATS_3"	{	Text	"Il Builder potera' i tuoi rami!"	}

	Sub	"MC2ATW_1"	{	Text	"Vedi gia', tu, la luce del tunnel?"	}

	Sub	"MC2ATW_2"	{	Text	"Cessa! Spira! Spegniti!"	}

	Sub	"MC2ATWW1"	{	Text	"Ancora uno a segno ed e' finita, buon ingranaggio!"	}

	Sub	"MC2BAK_1"	{	Text	"Ahhh... Era solo del muschio nei miei occhi, poiche' ora tutto e' chiaro."	}

	Sub	"MC2BAK_2"	{	Text	"Karras tempri i miei nervi, poiche' dopotutto non era nulla."	}

	Sub	"MC2BAK_3"	{	Text	"Hmm, di nuovo silenzio. Sia lodato il Builder."	}

	Sub	"MC2BAK_4"	{	Text	"Se era una caldaia, allora va revisionata presto, poiche' non dovrebbe tintinnare cosi'."	}

	Sub	"MC2BAK_5"	{	Text	"Hm, ora tutto e' quieto."	}

	Sub	"MC2BAK_6"	{	Text	"I ratti farebbero bene a sgattaiolare altrove."	}

	Sub	"MC2BKD_1"	{	Text	"Soffrirai presto... e muuorirai anche!"	}

	Sub	"MC2BKD_2"	{	Text	"Oh, lascia solo che ti abbatta, Herr Ladro!"	}

	Sub	"MC2BKD_3"	{	Text	"Ben parato, ladro, ma tutto invano!"	}

	Sub	"MC2BKDW1"	{	Text	"Una volta parato, due volte colpito, eeeh, Amico?"	}

	Sub	"MC2BLK_1"	{	Text	"Mi vantero' di cuore di questo scambio, ladro!"	}

	Sub	"MC2BLK_2"	{	Text	"Hai la forza di riprovare ancora... farabutto?"	}

	Sub	"MC2BLK_3"	{	Text	"Dovrai muoverti assai piu' in fretta, rospo!"	}

	Sub	"MC2BLKW1"	{	Text	"Ora gli manca combustibile, Amico!"	}

	Sub	"MC2BOD_1"	{	Text	"Assassinio! Preghero' per te piu' tardi, Amico, e ora ti vendichero'!"	}

	Sub	"MC2BOD_2"	{	Text	"Oh, omicidio turpissimo! Devo trovare il malfattore."	}

	Sub	"MC2BOD_3"	{	Text	"Assassino! Sei malvagissimo! Ti portero' la morte!"	}

	Sub	"MC2CHGA2"	{	Text	"Resta fermo e fatti schiacciare!"	}

	Sub	"MC2CHGA3"	{	Text	"Ti randellero'!"	}

	Sub	"MC2CHGW1"	{	Text	"Brandisci anche tu la mazza contro il farabutto, Amico!"	}

	Sub	"MC2CHGW2"	{	Text	"Addosso a lui, Amico!"	}

	Sub	"MC2CHGW3"	{	Text	"Brandiscila, Cog, brandisci!"	}

	Sub	"MC2DET_1"	{	Text	"Io sono il tuo incubo!"	}

	Sub	"MC2DET_2"	{	Text	"La morte e' il tuo destino, peccatore!"	}

	Sub	"MC2DET_3"	{	Text	"Sarebbe piu' efficiente se tu lasciassi che ti abbattessi ora!"	}

	Sub	"MC2DETW1"	{	Text	"Vedete come para il farabutto? Mirate oltre!"	}

	Sub	"MC2DIEA1"	{	Text	"Ooohm-mhh.. Bbulideeer..."	}

	Sub	"MC2DIEC1"	{	Text	"Aaaahh... si faa... buio..."	}

	Sub	"MC2FRUS1"	{	Text	"Ti pentirai di averci sfidati!"	}

	Sub	"MC2FRUS2"	{	Text	"Aarrhh... Maledetto!"	}

	Sub	"MC2FRUS3"	{	Text	"Puoi ridere per il momento, ma piangerai fra non molto!"	}

	Sub	"MC2HIT_1"	{	Text	"Una sepoltura da peccatore per te, ingranaggio arrugginito!"	}

	Sub	"MC2HIT_2"	{	Text	"Il tuo sangue puzza del tuo peccare!"	}

	Sub	"MC2HIT_3"	{	Text	"Terribile farabutto! Spira presto per me!"	}

	Sub	"MC2HIT_4"	{	Text	"Imparerai la lezione finale!"	}

	Sub	"MC2HITW1"	{	Text	"Mazze pronte, e addosso a lui!"	}

	Sub	"MC2HITW2"	{	Text	"Finiamo, noi, l'abbattimento di questo ramoscello!"	}

	Sub	"MC2HLOW1"	{	Text	"Aaahhh!.. Proteggimi, Amico!"	}

	Sub	"MC2HND_1"	{	Text	"Conobbi una volta un'effimera che mi colpi' con piu' dolore!"	}

	Sub	"MC2HND_2"	{	Text	"Hah! Nessun danno su di me! Come sta la tua mano?"	}

	Sub	"MC2HND_3"	{	Text	"Nell'armatura del Builder sono ben vestito!"	}

	Sub	"MC2LAR_1"	{	Text	"Ahime', un peccatore minaccia la nostra pace!"	}

	Sub	"MC2LAR_2"	{	Text	"Builder! Cerco il farabutto che disfa le tue opere! Quell'ingranaggio inadatto sara' riforgiato dalla mia ira!"	}

	Sub	"MC2LOS_1"	{	Text	"Per il Builder, ho perduto quel furfante!"	}

	Sub	"MC2LOS_2"	{	Text	"Hmmm... E' come se le ombre stesse lo avessero inghiottito."	}

	Sub	"MC2LOS_3"	{	Text	"Era proprio li'... e ora quel ladro mangiamuschio e' scomparso!"	}

	Sub	"MC2MIS_1"	{	Text	"No no! Furto! Non finche' respiro ancora!"	}

	Sub	"MC2MIS_2"	{	Text	"Ladro! Ti alleggeriro' delle tue mani maliziose!"	}

	Sub	"MC2RBOD1"	{	Text	"Unisciti a me! Cerco vendetta per coloro che sono caduti!"	}

	Sub	"MC2RBOD2"	{	Text	"Un assassino ci da' la caccia! Dobbiamo trovarlo per primi!"	}

	Sub	"MC2RINT1"	{	Text	"Sorveglia il tuo posto, Amico! Un intruso armato e' vicino."	}

	Sub	"MC2RINT2"	{	Text	"Tieni la mazza pronta! Un ladro s'insinua da questa parte!"	}

	Sub	"MC2RINT3"	{	Text	"Guardati dal farabutto... fin troppo armato. E' vicino!"	}

	Sub	"MC2RMIS2"	{	Text	"Era li' e poi sparito! Dobbiamo fermare questo ladro!"	}

	Sub	"MC2ROB_1"	{	Text	"Un vandalo e' tra noi!"	}

	Sub	"MC2ROB_2"	{	Text	"No! E' rovinato! Chiunque abbia fatto questo, ti trovero'!"	}

	Sub	"MC2ROB_3"	{	Text	"Guardate! E' opera di un vandalo!"	}

	Sub	"MC2ROTH1"	{	Text	"Amico, destati! Qualcosa non va!"	}

	Sub	"MC2ROTH2"	{	Text	"Aguzza occhi e orecchie! Il male e' in azione!"	}

	Sub	"MC2ROTH3"	{	Text	"Resta con me un poco! Credo che possano esserci guai!"	}

	Sub	"MC2RROB1"	{	Text	"Un vandalo e' tra noi! Sii vigile!"	}

	Sub	"MC2RUNA1"	{	Text	"Portate qui il vostro numero, Amici!"	}

	Sub	"MC2RUNA2"	{	Text	"Prestatemi i vostri combustibili! Presto, Amici!"	}

	Sub	"MC2RUNA3"	{	Text	"Sono assediato! Portatemi i vostri aiuti!"	}

	Sub	"MC2SEC_1"	{	Text	"Qualcuno gioca al misfatto!"	}

	Sub	"MC2SEC_2"	{	Text	"Controllate tutti i volti! Uno straniero cammina tra noi."	}

	Sub	"MC2SEC_3"	{	Text	"Un intruso ci assedia!"	}

	Sub	"MC2SMA_1"	{	Text	"Disfatto o fatto? In quale direzione sei stato visto l'ultima volta?"	}

	Sub	"MC2SMA_2"	{	Text	"Hmmm... Questo mi pesa in modo strano."	}

	Sub	"MC2TELC1"	{	Text	"Qui! Qui! Il ladro e' qui!"	}

	Sub	"MC2TELC2"	{	Text	"A me! Il farabutto e' stato scorto!"	}

	Sub	"MC2TELC3"	{	Text	"Guardate qui, Amici! L'intruso!"	}

	Sub	"MC2TELR1"	{	Text	"Ladro! Intruso! Aiutate i miei sforzi, Mechanists!"	}

	Sub	"MC2TELR2"	{	Text	"Ladro! Ferma il tradimento!"	}

	Sub	"MC2TELR3"	{	Text	"Che sorta di farabutto e' questo? Fermatelo!"	}

	Sub	"MC2TELR4"	{	Text	"Un intruso! Porremo fine al suo tradimento!"	}

	Sub	"MC2TORC1"	{	Text	"Hmmm... Strano che si faccia buio cosi' all'improvviso."	}

	Sub	"MC2TORC2"	{	Text	"Non riusciamo a tenere nulla in funzione?"	}
}

