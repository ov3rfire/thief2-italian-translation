	Sub	"HM1MIS_2"	{	Text	"Ladro! Saccheggiatore!"	}

	Sub	"HM1RBOD1"	{	Text	"L'intruso e' anche un assassino! Guardati le spalle!"	}

	Sub	"HM1RBOD2"	{	Text	"C'e' un assassino a piede libero! C'e' gia' stata una morte!"	}

	Sub	"HM1RINT1"	{	Text	"C'e' un ladro armato nell'edificio! Avventati su di lui se dovessi scorgerlo!"	}

	Sub	"HM1RINT2"	{	Text	"Ho scorto uno che potrebbe essere un prigioniero fuggito. Sii cauto!"	}

	Sub	"HM1RINT3"	{	Text	"Vi e' un intruso tra i Figli del Builder."	}

	Sub	"HM1RMIS1"	{	Text	"Dite al Master Forger che e' stato derubato."	}

	Sub	"HM1ROTH1"	{	Text	"Qualcuno e' stato qui dentro illegalmente. Tenete gli occhi aperti!"	}

	Sub	"HM1ROTH2"	{	Text	"Hai notato nulla? C'era qualcosa poco fa."	}

	Sub	"HM1ROTH3"	{	Text	"Sospetto che ci sia qualcuno nell'edificio. State all'erta."	}

	Sub	"HM1RUNA1"	{	Text	"A me, fratelli miei! Un intruso minaccia!"	}

	Sub	"HM1RUNA2"	{	Text	"Prendete le armi e venite qui!"	}

	Sub	"HM1RUNA3"	{	Text	"La nostra guardia e' messa alla prova! A me!"	}

	Sub	"HM1SEC_1"	{	Text	"Chi e' passato di qui?"	}

	Sub	"HM1SEC_2"	{	Text	"Un intruso viene tra noi!"	}

	Sub	"HM1SEC_3"	{	Text	"Attento a un intruso!"	}

	Sub	"HM1SMA_1"	{	Text	"Chi ha seminato rovina qui intorno?"	}

	Sub	"HM1SMA_2"	{	Text	"Questo disordine parla male."	}

	Sub	"HM1TELC1"	{	Text	"A me! Dietro di lui!"	}

	Sub	"HM1TELC2"	{	Text	"Da questa parte! L'intruso sta fuggendo!"	}

	Sub	"HM1TELC3"	{	Text	"L'intruso e' qui!"	}

	Sub	"HM1TELR1"	{	Text	"Abbiamo un intruso! Presto! A me!"	}

	Sub	"HM1TELR2"	{	Text	"Un intruso viene tra noi!"	}

	Sub	"HM1TELR3"	{	Text	"Guardati da questo farabutto!"	}
}

