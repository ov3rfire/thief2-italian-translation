{
	Type	"bark"
	Descr	"Machinist"

	Sub	"MC1A0CH1"	{	Text	"E Karras disse: ''Rendiamo grazie al Builder, poiche' Egli ha formato le mie mani con dita. Ed ecco, le mie dita s'incastrano come ingranaggi in una ruota dentata. Io sono parte della Sua macchina incontemplabile, e in cio' sta la mia salvezza.'"	}

	Sub	"MC1A0CH2"	{	Text	"In posizione salda, tu, la tua piastra, facendo combaciare A con A, e B con B, affinche' completo sia il tuo sigillo, una vera barriera che blocchi polvere e sudiciume--i nemici del buon ingranaggio."	}

	Sub	"MC1A0CH3"	{	Text	"La lealta' e' il combustibile che brucia via la giungla contorta... che giace oltre la casa di Karras."	}

	Sub	"MC1A0CH4"	{	Text	"Ed ecco: un Uomo verra' a te, e sara' guida di uomini; e sara' artefice di guerra, e sara' versatore di linfa, e sara' spargitore... di... sangue!"	}

	Sub	"MC1A0CH5"	{	Text	"Non forgiare tu il martello, ma sii fortificato dalla conoscenza del Builder e lascia allora che siano foggiate cose piu' alte. Allora prospererai."	}

	Sub	"MC1A0CH6"	{	Text	"I virgulti danzarono in modo cosi' innaturale che tememmo le forme... forgiate in modo empissimo, e vacillammo e prendemmo la fuga (??????)... finche' colui che e' Karras ci sollevo' contro di esse, cosi' che noi, l'uno e poi l'altro, ci sollevammo a nostra volta."	}

	Sub	"MC1A0CH7"	{	Text	"E Karras disse: ''Rendiamo grazie al Builder, poiche' Egli ha formato le mie mani con dita. Ed ecco, le mie dita s'incastrano come ingranaggi in una ruota dentata. Io sono parte della Sua macchina incontemplabile, e in cio' sta la mia salvezza.'"	}

	Sub	"MC1A0CH8"	{	Text	"In posizione salda, tu, la tua piastra, facendo combaciare A con A, e B con B, affinche' completo sia il tuo sigillo, una vera barriera che blocchi polvere e sudiciume--i nemici del buon ingranaggio."	}

	Sub	"MC1A0CH9"	{	Text	"Ed ecco: un Uomo verra' a te, e sara' guida di uomini; e sara' artefice di guerra, e sara' versatore di linfa, e sara' spargitore... di... sangue!"	}

	Sub	"MC1A0CHA"	{	Text	"I virgulti danzarono in modo cosi' innaturale che tememmo le forme... forgiate in modo empissimo, e vacillammo e prendemmo la fuga... finche' colui che e' Karras ci sollevo' contro di esse, cosi' che noi, l'uno e poi l'altro, ci sollevammo a nostra volta."	}

	Sub	"MC1A0CHB"	{	Text	"La lealta' e' il combustibile che brucia via la giungla contorta... che giace oltre la casa di Karras."	}
}

{
	Type	"urgent"
	Descr	"Machinist"

	Sub	"MC1A1__1"	{	Text	"Per amor di Karras, c'e' qualcuno?"	}

	Sub	"MC1A1__2"	{	Text	"Se c'e' qualcuno, allora si mostri!"	}

	Sub	"MC1A1__3"	{	Text	"Sei tu, Amico?"	}

	Sub	"MC1A1__4"	{	Text	"Vieni nella luce, affinche' io possa vederti!"	}

	Sub	"MC1A1_W1"	{	Text	"Fai rapporto, Amico. Hai forse notato qualcosa di spiacevole?"	}

	Sub	"MC1A1H_1"	{	Text	"E' la caldaia, questa, o forse qualcosa di peggio?"	}

	Sub	"MC1A1H_2"	{	Text	"Un rumore! Ne sono certo come del Builder in persona!"	}

	Sub	"MC1A1HW1"	{	Text	"Piano! Sono certo di aver udito qualcosa!"	}

	Sub	"MC1A1HW2"	{	Text	"Zittite i vostri ingranaggi! Ho udito un rumore!"	}

	Sub	"MC1A1HW3"	{	Text	"La'! Hai udito quello?"	}

	Sub	"MC1A1V_1"	{	Text	"Hmmm... Quale ombra e' passata alla mia vista?"	}

	Sub	"MC1A1VW1"	{	Text	"Parla, se hai veduto qualcosa, Amico."	}

	Sub	"MC1A1VW2"	{	Text	"Hai veduto quell'ombra muoversi?"	}

	Sub	"MC1A1VW3"	{	Text	"Di certo l'hai veduto anche tu?"	}

	Sub	"MC1A2__1"	{	Text	"Quale misfatto e' questo? Mostrati!"	}

	Sub	"MC1A2__2"	{	Text	"In nome di Karras, rivelati a me!"	}

	Sub	"MC1A2__3"	{	Text	"Dichia'rati, e non mettere oltre alla prova la mia pazienza!"	}

	Sub	"MC1A2H_1"	{	Text	"Ahaaa! Ti odo, intruso! Entra nella luce!"	}

	Sub	"MC1A2H_2"	{	Text	"Cessa il tuo gracidio e salta in vista... vile rospo!"	}

	Sub	"MC1A2SE1"	{	Text	"Vieni fuori, vieni fuori, ovunque tu sia!"	}

	Sub	"MC1A2SE2"	{	Text	"Odo il tuo cuore timoroso! Tum!... Tum!..."	}

	Sub	"MC1A2SE3"	{	Text	"Dove sei andato?"	}

	Sub	"MC1A2SE4"	{	Text	"Quale ombra ti tradisce?"	}

	Sub	"MC1A2V_1"	{	Text	"Sei rivelato, erbaccia! Pronuncia il tuo nome!"	}

	Sub	"MC1A3B_1"	{	Text	"Per Karras! Misfatto turpissimo!"	}

	Sub	"MC1A3B_2"	{	Text	"Un assassino! Che il Builder sia il tuo giudice!"	}

	Sub	"MC1A3NA1"	{	Text	"Fermo, ladro! La tua fuga e' sventata!"	}

	Sub	"MC1A3NA2"	{	Text	"Cessa i tuoi svolazzi e fermati!"	}

	Sub	"MC1A3NA3"	{	Text	"Alt, e ricevi il tuo taglio, virgulto!"	}

	Sub	"MC1A3NA4"	{	Text	"Alt! Cedi la tua arma!"	}

	Sub	"MC1A3S_1"	{	Text	"Ahhh! Da dove sei venuto, farabutto!"	}

	Sub	"MC1A3S_2"	{	Text	"Per Karras! Un'erbaccia!"	}

	Sub	"MC1A3S_3"	{	Text	"Caldaie!"	}

	Sub	"MC1A3S_4"	{	Text	"Sei generato dall'oscurita', farabutto!"	}

	Sub	"MC1A3SE1"	{	Text	"Palmo a palmo cerchero'... finche' non ti avro' trovato!"	}

	Sub	"MC1A3SE2"	{	Text	"Ti fiutero' presto, sudicia erbaccia!"	}

	Sub	"MC1A3SE3"	{	Text	"Karras guidera' la mia ricerca, infedele!"	}

	Sub	"MC1A3SE4"	{	Text	"Le ombre non possono nascondere la tua codardia!"	}

	Sub	"MC1ALMA1"	{	Text	"Ascolta il suono della tua rovina, farabutto!"	}

	Sub	"MC1ALMA2"	{	Text	"Date l'allarme! E convocate la morte per il nostro nemico!"	}

	Sub	"MC1ALMW1"	{	Text	"All'allarme, e fate presto!"	}

	Sub	"MC1AMB_1"	{	Text	"Ahh! Quale misfatto e' questo?"	}

	Sub	"MC1AMB_2"	{	Text	"Ahh! Ci vuole piu' di questo per privarmi del combustibile!"	}

	Sub	"MC1AMB_3"	{	Text	"Combattero' te, ombra!"	}

	Sub	"MC1AMB_4"	{	Text	"Ahhh! Codardo! Affrontami e combatti!"	}

	Sub	"MC1AMBW1"	{	Text	"Ahhh! Proteggimi, Amico, sono ferito!"	}

	Sub	"MC1AMBW2"	{	Text	"Ohh! Hai visto quale minaccia mi ha ferito?"	}

	Sub	"MC1AMBW3"	{	Text	"Ohhh! Sono ammaccato!"	}

	Sub	"MC1ATB_1"	{	Text	"Non sembrerai cosi' compiaciuto con il mio dardo dentro di te!"	}

	Sub	"MC1ATB_2"	{	Text	"Vola rapido e sicuro!"	}

	Sub	"MC1ATB_3"	{	Text	"Un dardo ti rallentera'!"	}

	Sub	"MC1ATL_1"	{	Text	"Scatena su di me, o Builder!"	}

	Sub	"MC1ATL_2"	{	Text	"Karras... forza a me!"	}

	Sub	"MC1ATN_1"	{	Text	"Sei schiacciato!"	}

	Sub	"MC1ATN_2"	{	Text	"Per gli ingranaggi, MORIRAI qui!"	}

	Sub	"MC1ATN_6"	{	Text	"Ti sradico, vile erbaccia!"	}

	Sub	"MC1ATN_7"	{	Text	"Sei pieno, crescita empia!"	}

	Sub	"MC1ATN_8"	{	Text	"Ti schiaccio, ingranaggio difettoso!"	}

	Sub	"MC1ATN_9"	{	Text	"Per Karras, e il Buildeeeerr!"	}

	Sub	"MC1ATS_1"	{	Text	"Che la volonta' di Karras ti colpisca!"	}

	Sub	"MC1ATS_2"	{	Text	"Cadi dinanzi al mio potere!"	}

	Sub	"MC1ATS_3"	{	Text	"Non ci turberai piu' a lungo!"	}

	Sub	"MC1ATW_1"	{	Text	"Il tuo combustibile e' quasi esaurito, intruso!"	}

	Sub	"MC1ATW_2"	{	Text	"Dov'e' ora il tuo valore?"	}

	Sub	"MC1ATWW1"	{	Text	"E' quasi esausto!"	}

	Sub	"MC1BAK_1"	{	Text	"Era solo il dolce tintinnio di una caldaia... assai probabilmente."	}

	Sub	"MC1BAK_2"	{	Text	"Il vento oggi mi gioca strani scherzi."	}

	Sub	"MC1BAK_3"	{	Text	"Erano foglie nelle mie orecchie a frusciare cosi', ma ora sono sparite."	}

	Sub	"MC1BAK_4"	{	Text	"Era certo solo muschio nei miei occhi."	}

	Sub	"MC1BAK_5"	{	Text	"Ratti! Tutti sudici e forgiati in modo empio... certo era solo quello."	}

	Sub	"MC1BAK_6"	{	Text	"Tutto e' di nuovo quieto, grazie siano rese a Karras."	}

	Sub	"MC1BAK_7"	{	Text	"Hmph... Nessun rumore ora, sia benedetto il Builder."	}

	Sub	"MC1BAK_8"	{	Text	"Dunque non era nulla? I tamburi nelle mie orecchie suonano troppo forte."	}

	Sub	"MC1BKD_1"	{	Text	"Una parata fortunata non ti salvera'!"	}

	Sub	"MC1BKD_2"	{	Text	"Il mio prossimo colpo trovera' il segno, germoglio!"	}

	Sub	"MC1BKD_3"	{	Text	"Builder, guida la mia mira!"	}

	Sub	"MC1BKDW1"	{	Text	"Vedi, tu, come ha sventato il mio colpo?"	}

	Sub	"MC1BLK_1"	{	Text	"Haha! Questa volta prova a colpire sul serio!"	}

	Sub	"MC1BLK_2"	{	Text	"Sono piu' veloce di te, farabutto!"	}

	Sub	"MC1BLK_3"	{	Text	"Sei sopraffatto, rospo!"	}

	Sub	"MC1BLKW1"	{	Text	"Ahh! Guarda come vacillano i traditori!"	}

	Sub	"MC1BOD_1"	{	Text	"Karras ci aiuti... morte assai prematura... assassinio!"	}

	Sub	"MC1BOD_2"	{	Text	"Il Builder protegge i Suoi servitori piu' fedeli! Karras ci protegge ora!"	}

	Sub	"MC1BOD_3"	{	Text	"Ahime', povero ingranaggio! Amici, siamo uno di meno! Assassinio!"	}

	Sub	"MC1CHGA1"	{	Text	"Per Karras e il Builder!"	}

	Sub	"MC1CHGA3"	{	Text	"Ti sradichero', erbaccia malvagia!"	}

	Sub	"MC1CHGW1"	{	Text	"Abbattiamo questo virgulto!"	}

	Sub	"MC1CHGW2"	{	Text	"Dietro di lui!"	}

	Sub	"MC1CHGW3"	{	Text	"Sradica questa erbaccia con me, Amico!"	}

	Sub	"MC1DET_1"	{	Text	"Accetta la volonta' di Karras!"	}

	Sub	"MC1DET_2"	{	Text	"Gioca a un gioco da codardi!"	}

	Sub	"MC1DET_3"	{	Text	"Non cercare di ritardare la tua sepoltura!"	}

	Sub	"MC1DETW1"	{	Text	"Vedi come spreca il nostro tempo, Amico?"	}

	Sub	"MC1DIEC1"	{	Text	"Sono... privo di combustibile..."	}

	Sub	"MC1FRUS1"	{	Text	"Non sarai cosi' felice quando i miei Amici ti scorgeranno!"	}

	Sub	"MC1FRUS2"	{	Text	"Non ci sfiderai per sempre!"	}

	Sub	"MC1FRUS3"	{	Text	"Karras ti abbattera'!"	}

	Sub	"MC1HIT_1"	{	Text	"La tua linfa cola via, mangiamuschio!"	}

	Sub	"MC1HIT_2"	{	Text	"Ti indebolisci!"	}

	Sub	"MC1HIT_3"	{	Text	"Il tuo destino e' segnato!"	}

	Sub	"MC1HIT_4"	{	Text	"Che dici ora, farabutto?"	}

	Sub	"MC1HITW1"	{	Text	"Sta perdendo vapore, Amico!"	}

	Sub	"MC1HITW2"	{	Text	"Insieme possiamo privarlo del combustibile!"	}

	Sub	"MC1HLO_1"	{	Text	"Karras, concedimi forza!"	}

	Sub	"MC1HLOW1"	{	Text	"Proteggimi, affinche' io non cada!"	}

	Sub	"MC1HND_1"	{	Text	"Colpo mal assestato, farabutto, e nessuna seconda occasione!"	}

	Sub	"MC1HND_2"	{	Text	"La fede rende la mia pelle come ferro, e le mie ossa come acciaio!"	}

	Sub	"MC1HND_3"	{	Text	"Mi combatti con la paglia?"	}

	Sub	"MC1LAR_1"	{	Text	"Quale evento e' questo?"	}

	Sub	"MC1LAR_2"	{	Text	"I miei occhi vedono correttamente?"	}

	Sub	"MC1LOS_1"	{	Text	"Le ombre stesse cospirano contro di me! Dove e' andato il ladro?"	}

	Sub	"MC1LOS_2"	{	Text	"Dov'e' andata quell'erbaccia?"	}

	Sub	"MC1LOS_3"	{	Text	"L'odore nocivo rimane, ma l'intruso e' fuggito!"	}

	Sub	"MC1MIS_1"	{	Text	"Per Karras! Chi osa praticare il furto qui?"	}

	Sub	"MC1MIS_2"	{	Text	"Sparito! Furto! Malefatta!"	}

	Sub	"MC1RBOD1"	{	Text	"Non abbassare la guardia, Amico! C'e' stato un omicidio."	}

	Sub	"MC1RBOD2"	{	Text	"L'intruso ha portato la morte tra noi! Pregate il Builder che il farabutto sia il prossimo!"	}

	Sub	"MC1RINT1"	{	Text	"Togliti le foglie dagli occhi, Amico. Un intruso armato e' tra noi."	}

	Sub	"MC1RINT2"	{	Text	"Ho scorto il ladro io stesso! Tieni, tu, combustibile nella tua caldaia!"	}

	Sub	"MC1RINT3"	{	Text	"Ho visto l'intruso. Resta pronto!"	}

	Sub	"MC1RMIS1"	{	Text	"Per Karras, qualcuno ha osato rubare a noi!"	}

	Sub	"MC1ROB_1"	{	Text	"Vandalo! Chi osa intromettersi nelle opere di Karras?"	}

	Sub	"MC1ROB_2"	{	Text	"C'e' un vandalo in mezzo a noi. Un Figlio di Karras e' distrutto!"	}

	Sub	"MC1ROB_3"	{	Text	"Guardate questa povera cosa, e' rovinata! E la colpa e' di un intruso!"	}

	Sub	"MC1ROTH1"	{	Text	"Sradica i tuoi piedi, Amico! Un intruso e' tra noi."	}

	Sub	"MC1ROTH2"	{	Text	"Hai visto una minaccia, o avevo muschio negli occhi?"	}

	Sub	"MC1ROTH3"	{	Text	"Temo un intruso, buon ingranaggio!"	}

	Sub	"MC1RUNA1"	{	Text	"Amici, a me! Che audacia e' questa?"	}

	Sub	"MC1RUNA2"	{	Text	"Armatevi e venite qui ora!"	}

	Sub	"MC1RUNA3"	{	Text	"Intruso! Portatemi il vostro aiuto, Amici!"	}

	Sub	"MC1SEC_1"	{	Text	"State all'erta! Un intruso e' venuto tra noi!"	}

	Sub	"MC1SEC_2"	{	Text	"C'e' un intruso! Di questo sono certo!"	}

	Sub	"MC1SEC_3"	{	Text	"Karras, dammi forza per affrontare questo nemico!"	}

	Sub	"MC1SMA_1"	{	Text	"Nessun Mechanist sarebbe tanto incauto!"	}

	Sub	"MC1SMA_2"	{	Text	"Chi osa intromettersi nelle opere?"	}

	Sub	"MC1TELC1"	{	Text	"Qui! Qui! L'intruso e' scoperto!"	}

	Sub	"MC1TELC2"	{	Text	"Fate presto! Il farabutto e' qui!"	}

	Sub	"MC1TELC3"	{	Text	"A me! E' stato trovato!"	}

	Sub	"MC1TELR1"	{	Text	"Intruso! Presto! Prestate aiuto!"	}

	Sub	"MC1TELR2"	{	Text	"Guardati da questo intruso, Amico."	}

	Sub	"MC1TELR3"	{	Text	"A me, buon ingranaggio! Abbiamo un intruso!"	}

	Sub	"MC1TORC1"	{	Text	"Maledizione! Non riusciamo a tenere nulla in funzione?"	}

	Sub	"MC1TORC2"	{	Text	"Certo... oscurita'. Fidati di un legno per fallire in un compito semplice!"	}

	Sub	"MC1TORC3"	{	Text	"Certo... oscurita'..."	}
}

