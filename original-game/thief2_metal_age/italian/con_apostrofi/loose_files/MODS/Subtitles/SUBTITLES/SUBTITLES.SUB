{
	Type	"bark"
	Descr	"Machinist"

	Sub	"MC3A0CH1"	{	Text	"I mantici sono bruciati, il piombo e' consumato dal fuoco, il fonditore fonde invano, poiche' i malvagi non sono strappati via."	}

	Sub	"MC3A0CH2"	{	Text	"Il carbone e' il combustibile, il combustibile e' posto nella fornace, la fornace viene accesa, quando accesa produce il calore, il calore scalda la forgia."	}

	Sub	"MC3A0CH3"	{	Text	"Io sono un ingranaggio nella ruota del Builder. Egli ha concepito il mondo e i suoi meccanismi sono inimmaginabili. Io sono vapore nel vapore del Builder. Egli ha soffiato luce nel mondo, e la sua vastita' e' invalicabile. Sia lode a Lui."	}

	Sub	"MC3A0CH4"	{	Text	"Affrettati quando puoi, affinche' tu possa prosperare su coloro che indugiano. Fatti numeroso quando vuoi, affinche' tu possa prosperare su coloro che sono pochi."	}

	Sub	"MC3A0CH5"	{	Text	"Guardatevi dal turpe, l'ingannatore degli uomini. Egli ha compiuto il male. Cosi' facilmente come io plasmo questo ferro, in forme magistrali troppo numerose da contare, guardatevi da cio' che egli ha forgiato."	}

	Sub	"MC3A0CH6"	{	Text	"Guai a coloro che non confidano in Karras. Dalla sua bocca risuona la volonta' del Builder. Dalla sua penna il piano del Builder viene diligentemente scritto. Guai a coloro che non confidano in Karras."	}

	Sub	"MC3A0MU1"	{	Text	"Le mie ossa, mentre sto qui... doloranti... Non posso aspettare. C'e' troppo nel vento... mi dolgono le giunture..."	}

	Sub	"MC3A0MU2"	{	Text	"Oh dio, ho fame. Staro' qui tutto il giorno e non mi portano da mangiare. Oh... il fondo del mio... stomaco mi duole come ieri, come fara' domani."	}

	Sub	"MC3A0MU3"	{	Text	"Oh, eccomi di nuovo al freddo e questo... gelo... Oh, i miei piedi sono ghiacciati fino all'osso."	}
}

{
	Type	"urgent"
	Descr	"Machinist"

	Sub	"MC3A1__1"	{	Text	"Pronto? C'e' qualcuno?"	}

	Sub	"MC3A1__2"	{	Text	"Se c'e' qualcuno, allora si dichiari!"	}

	Sub	"MC3A1__3"	{	Text	"Pronto? Rivelati!"	}

	Sub	"MC3A1__4"	{	Text	"Huh? Sei tu?"	}

	Sub	"MC3A1_W1"	{	Text	"Va tutto bene li', Amico?"	}

	Sub	"MC3A1H_1"	{	Text	"Cosa--? Pronto?"	}

	Sub	"MC3A1HW1"	{	Text	"Ascolta un poco! Amico, ho appena udito qualcosa!"	}

	Sub	"MC3A1HW2"	{	Text	"Shhhh! Sto cercando di udire quel rumore."	}

	Sub	"MC3A1HW3"	{	Text	"Presta orecchio, Amico! Ascolta con me un poco!"	}

	Sub	"MC3A1V_1"	{	Text	"Che cos'e' quello laggiu'?"	}

	Sub	"MC3A1VW1"	{	Text	"Guarda la', buon ingranaggio! Vedi forse qualcosa?"	}

	Sub	"MC3A1VW2"	{	Text	"La'! L'hai visto anche tu?"	}

	Sub	"MC3A1VW3"	{	Text	"Amico... credo che qualcosa si sia mosso la'!"	}

	Sub	"MC3A2__1"	{	Text	"C'e' qualcuno? Chi sei tu?"	}

	Sub	"MC3A2__2"	{	Text	"Aspetta! Mostrati!"	}

	Sub	"MC3A2__3"	{	Text	"Alt la'! Tu, sotto il manto dell'ombra!"	}

	Sub	"MC3A2__4"	{	Text	"Fermo! Resta li' e dichiarati!"	}

	Sub	"MC3A2H_1"	{	Text	"Ti odo! Vieni ora alla luce!"	}

	Sub	"MC3A2SE1"	{	Text	"Hmmm... dove puoi essere?"	}

	Sub	"MC3A2SE2"	{	Text	"Ti trovero'! Non puoi essere andato lontano."	}

	Sub	"MC3A2SE3"	{	Text	"Nulla e' nascosto cosi' bene che io non possa trovarlo!"	}

	Sub	"MC3A2SE4"	{	Text	"Chiunque tu sia, ti trovero'!"	}

	Sub	"MC3A2V_1"	{	Text	"Chi sei tu? Ti scorgo bene!"	}

	Sub	"MC3A3__3"	{	Text	"Cosa?"	}

	Sub	"MC3A3__4"	{	Text	"Cos'e' questo?"	}

	Sub	"MC3A3B_1"	{	Text	"Omicidio turpissimo! Alt la'!"	}

	Sub	"MC3A3B_2"	{	Text	"Cosa? E' omicidio? Lo vendichero'!"	}

	Sub	"MC3A3NA1"	{	Text	"Fermo la'! Intruso!"	}

	Sub	"MC3A3NA2"	{	Text	"Quale ombra ti ha generato? Fermo!"	}

	Sub	"MC3A3NA3"	{	Text	"Alt! Fermo! Intruso!"	}

	Sub	"MC3A3NA4"	{	Text	"Alt! Cedi la tua arma!"	}

	Sub	"MC3A3S_1"	{	Text	"Non sei il benvenuto qui, rospo!"	}

	Sub	"MC3A3S_2"	{	Text	"Per Karras, un intruso. Qui!"	}

	Sub	"MC3A3S_3"	{	Text	"Per Karras, un'erbaccia!"	}

	Sub	"MC3A3S_4"	{	Text	"Sei rivelato! Difenditi!"	}

	Sub	"MC3A3SE1"	{	Text	"Per ingranaggio e per ruota ti trovero'!"	}

	Sub	"MC3A3SE2"	{	Text	"Ti prometto un buon combattimento, ora fatti avanti!"	}

	Sub	"MC3A3SE3"	{	Text	"Sei forse codardo? Allora cessa di nasconderti!"	}

	Sub	"MC3A3SE4"	{	Text	"Sei un'orchidea traditrice, a ritrarti cosi' dalla luce!"	}

	Sub	"MC3A3SE5"	{	Text	"Smetti di nasconderti, malvagio!"	}

	Sub	"MC3ALMA1"	{	Text	"Date l'allarme! Non e' un'esercitazione!"	}

	Sub	"MC3ALMA2"	{	Text	"Devo recarmi all'allarme!"	}

	Sub	"MC3ALMW1"	{	Text	"Suonate l'allarme! Che risuoni la rovina del farabutto!"	}

	Sub	"MC3AMB_1"	{	Text	"Ah! Rivelami il tuo volto, codardo!"	}

	Sub	"MC3AMB_2"	{	Text	"Il tuo tradimento sara' smascherato, farabutto!"	}

	Sub	"MC3AMB_3"	{	Text	"Ah! Smetti di nasconderti e affrontami faccia a faccia!"	}

	Sub	"MC3AMB_4"	{	Text	"Oh! Chi mi colpisce all'improvviso da dietro?"	}

	Sub	"MC3AMBW1"	{	Text	"Cosa--? Una minaccia nascosta! Sono colpito!"	}

	Sub	"MC3AMBW2"	{	Text	"Le ombre stesse mi colpiscono, Amico!"	}

	Sub	"MC3AMBW3"	{	Text	"Cerca una perfida erbaccia, Amico, poiche' subdolamente sono stato colpito!"	}

	Sub	"MC3ATB_1"	{	Text	"Mirero' al tuo cuore, farabutto!"	}

	Sub	"MC3ATB_2"	{	Text	"Puoi continuare con il piede d'acciaio nelle viscere?"	}

	Sub	"MC3ATB_3"	{	Text	"Vedi la tua rovina sfrecciare verso di te?"	}

	Sub	"MC3ATL_1"	{	Text	"Karras... alimentami ora!"	}

	Sub	"MC3ATL_2"	{	Text	"La Tua forza a me... Builder!"	}

	Sub	"MC3ATN_1"	{	Text	"Mieti la mazza, farabutto!"	}

	Sub	"MC3ATN_2"	{	Text	"Come vivono gli ingiusti, cosi' moriranno!"	}

	Sub	"MC3ATN_6"	{	Text	"I tuoi giorni oscuri sono finiti!"	}

	Sub	"MC3ATN_7"	{	Text	"Non ci tormenterai piu'!"	}

	Sub	"MC3ATN_8"	{	Text	"Rospo ladro e traditore!"	}

	Sub	"MC3ATS_1"	{	Text	"La tua morte vola verso di te!"	}

	Sub	"MC3ATS_2"	{	Text	"Avvizzisci e marcisci, erbaccia!"	}

	Sub	"MC3ATS_3"	{	Text	"In nome di Karras, cadi!"	}

	Sub	"MC3ATW_1"	{	Text	"Ahaa! Poiche' io sono il felice vincitore!"	}

	Sub	"MC3ATW_2"	{	Text	"Ladro! Abbi paura, abbi molta paura!"	}

	Sub	"MC3ATWW1"	{	Text	"Cantiamo ora l'inno della vittoria, saldo ingranaggio!"	}

	Sub	"MC3BAK_1"	{	Text	"Nulla dunque. Ahhh... e' meglio cosi'."	}

	Sub	"MC3BAK_2"	{	Text	"Hm... Era solo un vento rancoroso, mandato a turbare la mia guardia."	}

	Sub	"MC3BAK_3"	{	Text	"Forse non era proprio nulla."	}

	Sub	"MC3BAK_4"	{	Text	"Era un ricordo di foglie che sbattevano. Nulla di piu'."	}

	Sub	"MC3BAK_5"	{	Text	"Ahhh... ora tutto sembra abbastanza bene."	}

	Sub	"MC3BAK_6"	{	Text	"In verita' non so cosa fosse."	}

	Sub	"MC3BAK_7"	{	Text	"Ahhh... il silenzio mi visita di nuovo. (Sospira) Benvenuto, amico!"	}

	Sub	"MC3BKD_1"	{	Text	"Il tuo braccio certamente cedera', poiche' il bene deve sempre prevalere!"	}

	Sub	"MC3BKD_2"	{	Text	"Una parata non ti salvera', rospo!"	}

	Sub	"MC3BKD_3"	{	Text	"Sii dunque avvertito! Il mio prossimo fendente andra' a segno!"	}

	Sub	"MC3BKDW1"	{	Text	"Assesta un colpo oltre le sue difese, Amico!"	}

	Sub	"MC3BLK_1"	{	Text	"I giusti sono protetti!"	}

	Sub	"MC3BLK_2"	{	Text	"Haaa! Sono piu' rapido di te!"	}

	Sub	"MC3BLK_3"	{	Text	"E' forse un uccello che mi becca? Colpisci sul serio!"	}

	Sub	"MC3BLKW1"	{	Text	"I suoi colpi cadono invano!"	}

	Sub	"MC3BOD_1"	{	Text	"Tradimento! Un Amico a terra e tutto privo di combustibile... Assassinio!"	}

	Sub	"MC3BOD_2"	{	Text	"Povero ingranaggio! Vendichero' il tuo assassinio, lo giuro!"	}

	Sub	"MC3BOD_3"	{	Text	"No! No! Dunque e' omicidio? Mostratemi il farabutto!"	}

	Sub	"MC3CHGA1"	{	Text	"Ti fracassero' la testa!"	}

	Sub	"MC3CHGA2"	{	Text	"Ti fracassero' la testa!"	}

	Sub	"MC3CHGA3"	{	Text	"Ti randellero', e per bene!"	}

	Sub	"MC3CHGW1"	{	Text	"Circondatelo! Attenti alla sua rovina!"	}

	Sub	"MC3CHGW2"	{	Text	"Colpiamo insieme, allora!"	}

	Sub	"MC3CHGW3"	{	Text	"Con le nostre forze unite, mirate alla testa!"	}

	Sub	"MC3DET_1"	{	Text	"Ho abbattuto alberi piu' grandi di te, virgulto!"	}

	Sub	"MC3DET_2"	{	Text	"Pensi forse di parare la volonta' del Builder?"	}

	Sub	"MC3DET_3"	{	Text	"Non hai udito? Il tradimento non ha difesa!"	}

	Sub	"MC3DETW1"	{	Text	"Rovescia la sua arroganza! Non lasciarlo pararti!"	}

	Sub	"MC3DIEC3"	{	Text	"Io--io cesso!"	}

	Sub	"MC3FRUS1"	{	Text	"Farabutto mangiafoglie!"	}

	Sub	"MC3FRUS2"	{	Text	"Vieni dove posso abbatterti!"	}

	Sub	"MC3FRUS3"	{	Text	"Smetti di coprirti, codardo!!"	}

	Sub	"MC3HIT_1"	{	Text	"Pronto per la tua mazzata finale?"	}

	Sub	"MC3HIT_2"	{	Text	"La mazza non ha pieta'!"	}

	Sub	"MC3HIT_3"	{	Text	"E il farabutto fu giustamente abbattuto!"	}

	Sub	"MC3HIT_4"	{	Text	"Ripercorri le disgrazie della tua vita, e in fretta!"	}

	Sub	"MC3HITW1"	{	Text	"Possiamo privarlo del combustibile, Amico! Colpisci di nuovo!"	}

	Sub	"MC3HITW2"	{	Text	"Amico, fa' che i colpi trovino il segno!"	}

	Sub	"MC3HLO_1"	{	Text	"Karras mi sostenga!"	}

	Sub	"MC3HLOW1"	{	Text	"Sto cedendo, Amico!"	}

	Sub	"MC3HND_1"	{	Text	"Il tuo colpo non morde, farabutto!"	}

	Sub	"MC3HND_2"	{	Text	"Un passero beccherebbe il fegato con piu' dolore, corvo!"	}

	Sub	"MC3HND_3"	{	Text	"Quello era un colpo? Heh! Che nemico tenero!"	}

	Sub	"MC3LAR_1"	{	Text	"Cercate un rospo traditore! Prendete le armi!"	}

	Sub	"MC3LAR_2"	{	Text	"Preparate le mazze! Un malfattore e' tra noi!"	}

	Sub	"MC3LOS_1"	{	Text	"Ho perso le sue tracce, quel rospo. Quell'erbaccia!"	}

	Sub	"MC3LOS_2"	{	Text	"Per Karras! Quel farabutto codardo deve essere fuggito."	}

	Sub	"MC3LOS_3"	{	Text	"Che serpente viscido! E' strisciato via del tutto!"	}

	Sub	"MC3MIS_1"	{	Text	"Dove e' andato ora?.. E come?"	}

	Sub	"MC3RBOD1"	{	Text	"Nessuna pieta', Amico! Del sangue e' gia' stato versato!"	}

	Sub	"MC3RINT1"	{	Text	"Resta alimentato! Poco fa ho scorto il ladro."	}

	Sub	"MC3RMIS1"	{	Text	"Attento al ladro! Resta all'erta!"	}

	Sub	"MC3ROB_1"	{	Text	"Oh no! Gentile Figlio di Karras, un tempo diligente e ora rovinato!"	}

	Sub	"MC3ROB_2"	{	Text	"Buon Figlio di Karras, riforgero' le tue parti, e trovero' il farabutto che ti ha spezzato!"	}

	Sub	"MC3ROB_3"	{	Text	"Cos'e' questo? Chi osa un simile vandalismo qui? Pagheranno per questo!"	}

	Sub	"MC3ROTH1"	{	Text	"Salute, buon ingranaggio! Tieni occhi e orecchie desti! Qualcosa non va!"	}

	Sub	"MC3ROTH2"	{	Text	"Destati vigile, buon Amico! Qualcosa di iniquo striscia vicino..."	}

	Sub	"MC3ROTH3"	{	Text	"Guardati! Notizie turbate parlano di questa guardia."	}

	Sub	"MC3RUNA1"	{	Text	"Amici! Prestatemi le vostre braccia contro il nemico piu' turpe!"	}

	Sub	"MC3RUNA2"	{	Text	"Qui! A me! Aiutatemi contro questo farabutto!"	}

	Sub	"MC3RUNA3"	{	Text	"Presto! Portate qui le vostre forze, Amici!"	}

	Sub	"MC3SEC_1"	{	Text	"Scovate il fuorilegge tra le nostre file!"	}

	Sub	"MC3SEC_2"	{	Text	"Attenti a un intruso e al suo tradimento!"	}

	Sub	"MC3SEC_3"	{	Text	"Tenete oliati i vostri ingranaggi da battaglia! Un intruso minaccia!"	}

	Sub	"MC3SMA_1"	{	Text	"Strano... queste notizie parlano male."	}

	Sub	"MC3SMA_2"	{	Text	"Hmmm... C'e' qualcosa di muschioso in tutto questo."	}

	Sub	"MC3TELC1"	{	Text	"Qui! E' qui!"	}

	Sub	"MC3TELC2"	{	Text	"L'ho trovato! Aiutatemi a schiacciare questo rospo!"	}

	Sub	"MC3TELC3"	{	Text	"Il farabutto e' qui! Che le mazze brandiscano!"	}

	Sub	"MC3TELR1"	{	Text	"Presta aiuto, buon ingranaggio! Un intruso e' qui!"	}

	Sub	"MC3TELR2"	{	Text	"Olia i tuoi ingranaggi da battaglia, Amico, poiche' un ladro ci turba!"	}

	Sub	"MC3TELR3"	{	Text	"Guarda qui! Un furfante virgulto!"	}

	Sub	"MC3TORC1"	{	Text	"Maledetta torcia! Perche' usiamo queste cose?"	}

	Sub	"MC3TORC2"	{	Text	"Hmm... La torcia si e' rotta?"	}

	Sub	"MC3TORC3"	{	Text	"Maledizione... Perche' usiamo queste cose?"	}
}

